---
import Container from "./Container.astro";

type Tone = "paper" | "paper-soft" | "ink" | "gold" | "submarca";
type Width = "narrow" | "default" | "wide";

interface Props {
  tone?: Tone;
  width?: Width;
  /** Color de submarca (hex o var). Solo aplica si tone="submarca". */
  accent?: string;
  /** Padding-block. Default usa el canónico. */
  spacing?: "default" | "tight" | "loose" | "none";
  as?: "section" | "div" | "article";
  id?: string;
  class?: string;
}

const {
  tone = "paper",
  width = "default",
  accent,
  spacing = "default",
  as = "section",
  id,
  class: className = "",
} = Astro.props;

const Tag = as;

const toneClasses: Record<Tone, string> = {
  paper: "bg-[var(--color-paper)] text-[var(--color-ink)]",
  "paper-soft": "bg-[var(--color-paper-soft)] text-[var(--color-ink)]",
  ink: "bg-[var(--color-ink)] text-[var(--color-paper)]",
  gold: "bg-[var(--color-gold)] text-[var(--color-paper)]",
  submarca: "text-[var(--color-ink)]",
};

const spacingClasses: Record<NonNullable<Props["spacing"]>, string> = {
  default: "py-[clamp(3rem,8vw,6rem)]",
  tight: "py-[clamp(2rem,5vw,3.5rem)]",
  loose: "py-[clamp(4rem,10vw,8rem)]",
  none: "",
};

const styleAttr = tone === "submarca" && accent ? `background:${accent}` : "";
---

<Tag
  id={id}
  style={styleAttr}
  class={`${toneClasses[tone]} ${spacingClasses[spacing]} ${className}`}
>
  <Container width={width}>
    <slot />
  </Container>
</Tag>
