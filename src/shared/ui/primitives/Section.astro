---
import Container from "./Container.astro";

type Tone = "paper" | "paper-soft" | "ink" | "gold" | "submarca";
type Width = "narrow" | "default" | "wide";

interface Props {
  tone?: Tone;
  width?: Width;
  /** Color de submarca (hex o var). Solo aplica si tone="submarca". */
  accent?: string;
  /** Padding-block. Default usa el canónico. */
  spacing?: "default" | "tight" | "loose" | "none";
  as?: "section" | "div" | "article";
  id?: string;
  class?: string;
}

const {
  tone = "paper",
  width = "default",
  accent,
  spacing = "default",
  as = "section",
  id,
  class: className = "",
} = Astro.props;

const Tag = as;

const toneClasses: Record<Tone, string> = {
  paper: "bg-[var(--color-paper)] text-[var(--color-ink)]",
  "paper-soft": "bg-[var(--color-paper-soft)] text-[var(--color-ink)]",
  ink: "bg-[var(--color-ink)] text-[var(--color-paper)]",
  // Pattern de swirls del manual (pág. 22 "Marca Matriz") superpuesto sobre el dorado
  // de marca con mix-blend-mode overlay, manteniendo la coherencia editorial.
  gold:
    "relative bg-[var(--color-gold)] text-[var(--color-paper)] bg-[url('/brand/cemad-pattern-swirls.jpg')] bg-cover bg-center bg-blend-overlay",
  submarca: "text-[var(--color-ink)]",
};

const spacingClasses: Record<NonNullable<Props["spacing"]>, string> = {
  default: "py-[clamp(3rem,8vw,6rem)]",
  tight: "py-[clamp(2rem,5vw,3.5rem)]",
  loose: "py-[clamp(4rem,10vw,8rem)]",
  none: "",
};

// Submarca: aplica un overlay sutil oscuro para garantizar contraste 4.5:1
// del texto blanco sobre los acentos claros (rose, silver).
const styleAttr =
  tone === "submarca" && accent
    ? `background-color:${accent};background-image:linear-gradient(to bottom, rgb(0 0 0 / 0.18), rgb(0 0 0 / 0.32))`
    : "";
---

<Tag
  id={id}
  style={styleAttr}
  class={`${toneClasses[tone]} ${spacingClasses[spacing]} ${className}`}
>
  <Container width={width}>
    <slot />
  </Container>
</Tag>
