---
type Variant = "primary" | "secondary" | "ghost" | "outline" | "submarca";
type Size = "sm" | "md" | "lg";

interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: Variant;
  size?: Size;
  /** Para variant="submarca": color hex o var. */
  accent?: string;
  /** Color sobre el accent (texto). Default: paper. */
  accentText?: string;
  fullWidth?: boolean;
  ariaLabel?: string;
  class?: string;
  disabled?: boolean;
  rel?: string;
  target?: "_blank" | "_self";
}

const {
  href,
  type = "button",
  variant = "primary",
  size = "md",
  accent,
  accentText = "var(--color-paper)",
  fullWidth = false,
  ariaLabel,
  class: className = "",
  disabled = false,
  rel,
  target,
} = Astro.props;

const isLink = !!href;
const Tag = isLink ? "a" : "button";

const baseClasses =
  "btn-base relative overflow-hidden inline-flex items-center justify-center gap-2 font-[family-name:var(--font-body)] font-bold rounded-none transition-[background,color,border-color,transform,box-shadow] duration-[var(--duration-fast)] ease-[var(--ease-out)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-dark)] disabled:opacity-50 disabled:cursor-not-allowed";

const sizeMap: Record<Size, string> = {
  sm: "min-h-[36px] px-4 text-[var(--text-sm)]",
  md: "min-h-[44px] px-6 text-[var(--text-base)]", // a11y target
  lg: "min-h-[52px] px-8 text-[var(--text-lg)]",
};

const variantMap: Record<Variant, string> = {
  primary:
    "btn-primary bg-[var(--color-gold)] text-[var(--color-paper)] hover:bg-[var(--color-gold-dark)] active:translate-y-px",
  secondary:
    "bg-[var(--color-ink)] text-[var(--color-paper)] hover:bg-black active:translate-y-px",
  ghost:
    "bg-transparent text-[var(--color-ink)] hover:bg-[var(--color-paper-soft)]",
  outline:
    "bg-transparent text-[var(--color-ink)] border border-[var(--color-mute)] hover:border-[var(--color-ink)]",
  submarca: "active:translate-y-px",
};

const submarcaStyle =
  variant === "submarca" && accent
    ? `background:${accent};color:${accentText}`
    : undefined;

const finalClass = [
  baseClasses,
  sizeMap[size],
  variantMap[variant],
  fullWidth ? "w-full" : "",
  className,
].join(" ");

const linkRel =
  target === "_blank" ? `${rel ?? ""} noopener noreferrer`.trim() : rel;
---

<style>
  /* Premium primary: gold shadow lift + sheen sweep on hover (desktop hover-capable only). */
  .btn-primary {
    box-shadow: 0 1px 2px rgb(0 0 0 / 0.08);
  }
  @media (hover: hover) {
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px oklch(56% 0.075 76 / 0.28);
    }
  }
  .btn-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgb(255 255 255 / 0.32) 50%,
      transparent 60%
    );
    transform: translateX(-120%);
    pointer-events: none;
  }
  @media (hover: hover) {
    .btn-primary:hover::before {
      transform: translateX(120%);
      transition: transform 700ms var(--ease-out);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn-primary,
    .btn-primary:hover {
      transform: none;
      transition: none;
    }
    .btn-primary::before { display: none; }
  }
</style>

{
  isLink ? (
    <a
      href={href}
      class={finalClass}
      style={submarcaStyle}
      aria-label={ariaLabel}
      rel={linkRel}
      target={target}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={finalClass}
      style={submarcaStyle}
      aria-label={ariaLabel}
      disabled={disabled}
    >
      <slot />
    </button>
  )
}
