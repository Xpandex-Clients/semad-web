---
type Width = "narrow" | "default" | "wide";
type As = "div" | "section" | "article" | "header" | "footer" | "nav" | "main";

interface Props {
  width?: Width;
  as?: As;
  class?: string;
}

const { width = "default", as = "div", class: className = "" } = Astro.props;
const Tag = as;

const widthMap: Record<Width, string> = {
  narrow: "max-w-[var(--container-narrow)]",
  default: "max-w-[var(--container-default)]",
  wide: "max-w-[var(--container-wide)]",
};
---

<Tag
  class={`mx-auto px-[clamp(1rem,4vw,2rem)] w-full ${widthMap[width]} ${className}`}
>
  <slot />
</Tag>
