---
/**
 * Logo CEMAD — versiones (manual de identidad p. 27).
 *
 * Por ahora usa PNGs interim extraídos del PDF. Cuando la cliente
 * aporte SVG vectorial, sustituir por <svg> inline (ver TODO en
 * design-system.md y CONTEXT-project.md).
 */

type Variant = "principal" | "vertical" | "isotipo" | "sello";
type Tone = "color" | "white" | "ink";

interface Props {
  variant?: Variant;
  tone?: Tone;
  /** Anchos mínimos del manual (p.28): principal 140px, vertical 165px, isotipo 35px. */
  width?: number;
  /** Hace que el ancho sea fluido hasta el max width. */
  fluid?: boolean;
  /** Texto del alt accesible (default: nombre completo). */
  alt?: string;
  class?: string;
}

const {
  variant = "principal",
  tone = "color",
  width,
  fluid = false,
  alt = "CEMAD — Aesthetic Anti-Aging Clinic",
  class: className = "",
} = Astro.props;

// El PNG `cemad-logo-principal.png` lleva el lockup blanco sobre placa dorada
// (versión sobre fondo dorado del manual). Para uso sobre fondos claros/oscuros
// elegimos directamente el archivo correcto en lugar de aplicar filtros sobre
// el PNG con fondo de color.
const principalByTone: Record<Tone, string> = {
  color: "/brand/cemad-logo-gold.png",   // logotipo dorado sobre transparente
  white: "/brand/cemad-logo-white.png",  // logotipo blanco sobre transparente
  ink: "/brand/cemad-logo-ink.png",      // logotipo tinta sobre transparente
};

const fileMap: Record<Variant, string> =
  variant === "principal"
    ? {
        principal: principalByTone[tone],
        vertical: "/brand/cemad-logo-vertical.png",
        isotipo: "/brand/cemad-isotipo-monograma.png",
        sello: "/brand/cemad-isotipo-sello.png",
      }
    : {
        principal: "/brand/cemad-logo-gold.png",
        vertical: "/brand/cemad-logo-vertical.png",
        isotipo: "/brand/cemad-isotipo-monograma.png",
        sello: "/brand/cemad-isotipo-sello.png",
      };

const minWidth: Record<Variant, number> = {
  principal: 140,
  vertical: 165,
  isotipo: 35,
  sello: 80,
};

const w = width ?? minWidth[variant] * 1.6;

// Para vertical/isotipo/sello mantenemos los filtros como interim si tone≠color.
const toneFilter: Record<Tone, string | undefined> = {
  color: undefined,
  white: variant === "principal" ? undefined : "brightness(0) invert(1)",
  ink: variant === "principal" ? undefined : "brightness(0)",
};

const styleAttr = [
  `width:${w}px`,
  fluid ? "max-width:100%;height:auto" : "",
  toneFilter[tone] ? `filter:${toneFilter[tone]}` : "",
]
  .filter(Boolean)
  .join(";");
---

<img
  src={fileMap[variant]}
  alt={alt}
  width={w}
  height="auto"
  loading="eager"
  decoding="async"
  style={styleAttr}
  class={`block ${className}`}
/>
