---
/**
 * Logo CEMAD — fuente única de verdad.
 *
 * Renderizado vectorial del frame `logo` (node 7:4) del Figma CLINICA CEMAD.
 * 465×138 con monogram CEMAD® serif + tagline "AESTHETIC ANTI-AGING CLINIC".
 *
 * Color por defecto: dorado de marca #BD9B5F.
 * tone="white" invierte a blanco (mediante filter) para fondos oscuros.
 */
type Tone = "color" | "white" | "ink";

interface Props {
  tone?: Tone;
  /** Ancho en px (default 150). El alto se calcula proporcionalmente. */
  width?: number;
  fluid?: boolean;
  alt?: string;
  class?: string;
}

const {
  tone = "color",
  width = 150,
  fluid = false,
  alt = "CEMAD — Aesthetic Anti-Aging Clinic",
  class: className = "",
} = Astro.props;

// Logo SVG reconstruido desde las 31 path geometries del nodo 221:782 del Figma
// (sans-serif geométrica + diamante en la C + tagline AESTHETIC ANTI-AGING CLINIC).
// Color base = negro #000. tone=white usa la variante invertida.
const src =
  tone === "white" ? "/brand/cemad-logo-white.svg" : "/brand/cemad-logo.svg";

const filter = undefined;

const styleAttr = [
  `width:${width}px`,
  fluid ? "max-width:100%;height:auto" : "",
  filter,
]
  .filter(Boolean)
  .join(";");
---

<img
  src={src}
  alt={alt}
  width={width}
  loading="eager"
  decoding="async"
  style={styleAttr}
  class={`block ${className}`}
/>
