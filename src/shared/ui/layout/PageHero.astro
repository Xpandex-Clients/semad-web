---
/**
 * PageHero — patrón Figma "interior page hero" fullbleed:
 *   imagen edge-to-edge bajo el header sticky + título overlay bottom-left.
 *
 * Props:
 *   - eyebrow:  preposición pequeña (ej. "Centro de Excelencia en")
 *   - title:    palabra fuerte gold script (ej. "Tricología:")
 *   - subtitle: línea inferior light (opcional)
 *   - intro:    párrafo opcional sobre fondo paper bajo el bleed
 */
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  focal?: string;
  eyebrow?: string;
  title: string;
  subtitle?: string;
  intro?: string;
}

const {
  image,
  alt,
  focal = "center center",
  eyebrow,
  title,
  subtitle,
  intro,
} = Astro.props;
---

<section
  class="relative isolate overflow-hidden bg-[var(--color-ink)] h-[min(95vh,640px)] sm:h-[min(85vh,720px)] lg:h-[min(90vh,820px)]"
  style="margin-top:-88px"
>
  <Picture
    src={image}
    alt={alt}
    widths={[768, 1024, 1440, 1920]}
    sizes="100vw"
    formats={["avif", "webp"]}
    quality={84}
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover"
    style={`object-position:${focal}`}
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-t from-[var(--color-ink)]/70 via-[var(--color-ink)]/15 to-[var(--color-ink)]/45"
  ></div>
  <div class="absolute inset-x-0 bottom-0">
    <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] py-[clamp(2rem,5vw,4rem)] text-[var(--color-paper)]">
      <h1 class="font-[family-name:var(--font-display)] font-light leading-[1.02]">
        {eyebrow && (
          <span class="block text-[clamp(1.125rem,1.8vw,1.5rem)] font-light text-[var(--color-paper)]/85">
            {eyebrow}
          </span>
        )}
        <em class="block not-italic italic text-[clamp(2.75rem,6.5vw,5.25rem)] font-normal mt-1 text-[var(--color-gold)]">
          <span class="inline-block w-[clamp(2rem,4vw,3rem)] h-[2px] bg-[var(--color-gold)] align-middle mr-3 mb-3"></span>{title}
        </em>
        {subtitle && (
          <span class="block mt-3 text-[clamp(1.25rem,2.5vw,2rem)] font-light text-[var(--color-paper)]">
            {subtitle}
          </span>
        )}
      </h1>
    </div>
  </div>
</section>
{intro && (
  <div class="bg-[var(--color-paper)]">
    <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] py-[clamp(2rem,5vw,4rem)]">
      <p class="max-w-[64ch] text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
        {intro}
      </p>
    </div>
  </div>
)}
