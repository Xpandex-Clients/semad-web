---
/**
 * PageHero — patrón Figma "interior page hero":
 *   full-bleed image + título overlay debajo del bleed.
 *   - eyebrow:  preposición pequeña (ej. "Centro de Excelencia en")
 *   - title:    palabra fuerte serif italic gold (ej. "Tricología:")
 *   - subtitle: línea inferior negra serif light (opcional)
 *   - intro:    párrafo corto bajo el título (opcional)
 */
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  /** Posición del foco (object-position) */
  focal?: string;
  /** Línea pequeña encima del título principal. */
  eyebrow?: string;
  /** Título principal (palabra gold italic, e.g. "Kintsugi:"). */
  title: string;
  /** Subtítulo opcional bajo el título principal (negro serif light). */
  subtitle?: string;
  /** Párrafo intro corto opcional. */
  intro?: string;
}

const {
  image,
  alt,
  focal = "center center",
  eyebrow,
  title,
  subtitle,
  intro,
} = Astro.props;
---

<section class="relative isolate overflow-hidden bg-[var(--color-paper)]">
  <!-- 1440/645 = 2.23 (Figma) — un poco más bajo en mobile para evitar imagen vertical estrecha -->
  <div class="relative aspect-[4/3] sm:aspect-[16/10] lg:aspect-[16/7] w-full overflow-hidden">
    <Picture
      src={image}
      alt={alt}
      widths={[768, 1024, 1440, 1920]}
      sizes="100vw"
      formats={["avif", "webp"]}
      quality={84}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
      style={`object-position:${focal}`}
    />
  </div>

  <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] pt-10 pb-4">
    <h1 class="font-[family-name:var(--font-display)] font-light leading-[1.02] text-[var(--color-ink)]">
      {eyebrow && (
        <span class="block text-[clamp(1.25rem,2.2vw,1.75rem)] font-light text-[var(--color-ink)]">
          {eyebrow}
        </span>
      )}
      <em class="block not-italic italic text-[clamp(3rem,7vw,6rem)] font-normal mt-1 text-[var(--color-gold)] -indent-[0.1em]">
        <span class="inline-block w-[clamp(2rem,4vw,3rem)] h-[2px] bg-[var(--color-gold)] align-middle mr-3 mb-3"></span>{title}
      </em>
      {subtitle && (
        <span class="block mt-3 text-[clamp(1.25rem,2.5vw,2rem)] font-light">
          {subtitle}
        </span>
      )}
    </h1>
    {intro && (
      <p class="mt-6 max-w-[58ch] text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
        {intro}
      </p>
    )}
  </div>
</section>
