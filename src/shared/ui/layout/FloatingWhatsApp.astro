---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@shared/config/site";

interface Props {
  message?: string;
}

const { message = `Hola, me gustaría reservar una consulta en ${siteConfig.name}.` } = Astro.props;

const cleanPhone = siteConfig.contact.whatsapp.replace(/[^0-9]/g, "");
const href = `https://wa.me/${cleanPhone}?text=${encodeURIComponent(message)}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Escribir por WhatsApp a ${siteConfig.name}`}
  class="fixed bottom-5 right-5 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#25D366] text-white shadow-[var(--shadow-modal)] transition-transform duration-200 ease-[var(--ease-out)] hover:scale-110 hover:shadow-[0_12px_32px_-4px_rgba(37,211,102,0.45)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-dark)] sm:bottom-7 sm:right-7 sm:h-16 sm:w-16"
>
  <Icon name="simple-icons:whatsapp" class="size-7 sm:size-8" aria-hidden="true" />
  <span class="pointer-events-none absolute inset-0 -z-10 animate-[ping_2.4s_cubic-bezier(0,0,0.2,1)_infinite] rounded-full bg-[#25D366]/40 motion-reduce:animate-none"></span>
</a>
