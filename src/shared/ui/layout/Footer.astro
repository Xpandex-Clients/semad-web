---
import Logo from "@shared/ui/brand/Logo.astro";
import { siteConfig } from "@shared/config/site";
import { submarcasNav, legalNav } from "@shared/config/navigation";

const year = new Date().getFullYear();
const waNumber = siteConfig.contact.whatsapp.replace(/[^0-9]/g, "");
---

<footer class="bg-[var(--color-ink)] text-[var(--color-paper)]">
  <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] py-[clamp(3rem,6vw,5rem)]">
    <div class="grid gap-12 md:grid-cols-3">
      <!-- Marca + dirección -->
      <div>
        <Logo variant="lockup-isotipo" tone="white" width={210} alt={`${siteConfig.name} — Aesthetic Anti-Aging Clinic`} />
        <p class="mt-4 font-[family-name:var(--font-script)] text-2xl text-[var(--color-gold-light)]">
          Tu Mejor Versión
        </p>
        <address class="not-italic mt-6 text-sm text-[var(--color-paper)]/80 leading-relaxed">
          {siteConfig.address.street}<br />
          {siteConfig.address.postalCode} · {siteConfig.address.locality}<br />
          {siteConfig.address.countryName}
        </address>
        <div class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm">
          <a
            href={`tel:${siteConfig.contact.phone}`}
            class="hover:text-[var(--color-gold-light)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)] rounded-[var(--radius-xs)]"
          >
            {siteConfig.contact.phoneDisplay}
          </a>
          <a
            href={`https://wa.me/${waNumber}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-gold-light)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)] rounded-[var(--radius-xs)]"
          >
            WhatsApp
          </a>
          <a
            href={siteConfig.contact.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[var(--color-gold-light)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)] rounded-[var(--radius-xs)]"
          >
            {siteConfig.contact.instagramHandle}
          </a>
        </div>
      </div>

      <!-- Especialidades -->
      <nav aria-label="Especialidades">
        <p class="text-xs uppercase tracking-[0.12em] text-[var(--color-mute)]">
          Especialidades
        </p>
        <ul class="mt-3 space-y-2 list-none p-0">
          {
            submarcasNav.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="inline-flex items-center gap-3 group focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)] rounded-[var(--radius-xs)]"
                >
                  <span
                    class="size-2 rounded-full shrink-0"
                    style={`background:${s.color}`}
                    aria-hidden="true"
                  />
                  <span class="text-sm group-hover:text-[var(--color-gold-light)] transition-colors">
                    {s.shortLabel}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- CTA + horarios -->
      <div>
        <p class="text-xs uppercase tracking-[0.12em] text-[var(--color-mute)]">
          Reserva tu consulta
        </p>
        <p class="mt-3 text-sm text-[var(--color-paper)]/80 max-w-[40ch]">
          Empieza por una conversación con la {siteConfig.doctor.name}.
          Te respondemos en menos de 24 horas.
        </p>
        <a
          href="/contacto"
          class="mt-4 inline-flex items-center justify-center min-h-[44px] px-6 rounded-[var(--radius-sm)] bg-[var(--color-gold)] text-[var(--color-paper)] font-medium hover:bg-[var(--color-gold-light)] hover:text-[var(--color-ink)] transition-colors focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)]"
        >
          Reservar consulta →
        </a>

        <p class="mt-8 text-xs uppercase tracking-[0.12em] text-[var(--color-mute)]">
          Horarios
        </p>
        <p class="mt-2 text-sm text-[var(--color-paper)]/80">
          L–V {siteConfig.hours.monday}<br />
          Sábado {siteConfig.hours.saturday}<br />
          Domingo {siteConfig.hours.sunday}
        </p>
        <p class="mt-1 text-xs text-[var(--color-mute)]">
          [TODO: confirmar horarios reales con la cliente]
        </p>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/10 flex flex-wrap gap-4 items-center justify-between text-xs text-[var(--color-mute)]">
      <p>© {year} {siteConfig.legalName}. Todos los derechos reservados.</p>
      <ul class="flex flex-wrap gap-x-5 gap-y-2 list-none p-0 m-0">
        {
          legalNav.map((item) => (
            <li>
              <a
                href={item.href}
                class="hover:text-[var(--color-paper)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)] rounded-[var(--radius-xs)]"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <p class="mt-4 text-[11px] text-[var(--color-mute)]/70">
      Desarrollado por
      <a
        href="https://xpandex.es"
        target="_blank"
        rel="noopener external"
        class="text-[var(--color-mute)] hover:text-[var(--color-paper)] underline-offset-2 hover:underline"
      >
        Xpandex
      </a>
    </p>
  </div>
</footer>
