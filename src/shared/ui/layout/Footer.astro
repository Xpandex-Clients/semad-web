---
import Logo from "@shared/ui/brand/Logo.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@shared/config/site";

const year = new Date().getFullYear();

const legalLinks = [
  { label: "Política de Privacidad", href: "/politica-privacidad" },
  { label: "Términos & Condiciones", href: "/aviso-legal" },
  { label: "Aviso Legal", href: "/aviso-legal" },
  { label: "Cookies", href: "/politica-cookies" },
];

const socials = [
  { name: "Facebook", href: siteConfig.contact.facebook, icon: "simple-icons:facebook" },
  { name: "LinkedIn", href: siteConfig.contact.linkedin, icon: "simple-icons:linkedin" },
  { name: "Instagram", href: siteConfig.contact.instagram, icon: "simple-icons:instagram" },
  { name: "YouTube", href: siteConfig.contact.youtube, icon: "simple-icons:youtube" },
];
---

<footer class="bg-[var(--color-ink)] text-[var(--color-paper)]">
  <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] pt-[clamp(2.5rem,5vw,4rem)] pb-8">

    <!-- Wordmark con hairlines a cada lado (espejo del navbar) -->
    <div class="relative mb-12 lg:mb-16">
      <div aria-hidden="true" class="absolute inset-x-0 top-1/2 -translate-y-1/2 flex items-center">
        <span class="footer-hairline flex-1 h-px"></span>
        <span class="w-[clamp(170px,16vw,210px)] shrink-0"></span>
        <span class="footer-hairline flex-1 h-px"></span>
      </div>
      <div class="relative flex justify-center">
        <Logo tone="white" width={150} alt={`${siteConfig.name} — inicio`} />
      </div>
    </div>

    <!-- 4 columnas (Figma) -->
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Sobre Cemad -->
      <div>
        <p class="font-[family-name:var(--font-display)] text-[1.1rem] text-[var(--color-paper)]">
          Sobre Cemad
        </p>
        <p class="mt-5 text-sm text-[var(--color-paper)]/70 leading-relaxed max-w-[28ch]">
          Clínica estética y capilar que restaura tu identidad con precisión médica y alma.
        </p>
        <ul class="mt-6 flex items-center gap-3 list-none p-0">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${s.name} CEMAD`}
                class="size-8 inline-flex items-center justify-center rounded-full border border-[var(--color-paper)]/30 text-[var(--color-paper)] hover:bg-[var(--color-gold)] hover:border-[var(--color-gold)] transition-colors"
              >
                <Icon name={s.icon} class="size-[14px]" aria-hidden="true" />
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legales -->
      <nav aria-label="Legales">
        <p class="font-[family-name:var(--font-display)] text-[1.1rem] text-[var(--color-paper)]">
          Legales
        </p>
        <ul class="mt-5 space-y-3 list-none p-0">
          {legalLinks.map((item) => (
            <li class="flex items-start gap-3">
              <span aria-hidden="true" class="mt-[0.65em] block w-3 h-px bg-[var(--color-paper)]/60 shrink-0"></span>
              <a
                href={item.href}
                class="text-sm text-[var(--color-paper)]/75 hover:text-[var(--color-gold-light)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)] rounded-[var(--radius-xs)]"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Nosotros -->
      <div>
        <p class="font-[family-name:var(--font-display)] text-[1.1rem] text-[var(--color-paper)]">
          Nosotros
        </p>
        <ul class="mt-5 space-y-3 list-none p-0 text-sm">
          <li class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="size-4 mt-0.5 text-[var(--color-gold)] shrink-0" aria-hidden="true" />
            <address class="not-italic text-[var(--color-paper)]/75 leading-relaxed">
              {siteConfig.address.street}, {siteConfig.address.locality} centro, {siteConfig.address.locality} {siteConfig.address.postalCode}
            </address>
          </li>
          <li>
            <a
              href={`mailto:${siteConfig.contact.email}`}
              class="flex items-center gap-3 text-[var(--color-paper)]/75 hover:text-[var(--color-gold-light)]"
            >
              <Icon name="lucide:mail" class="size-4 text-[var(--color-gold)]" aria-hidden="true" />
              {siteConfig.contact.email}
            </a>
          </li>
          <li class="flex items-center gap-3 text-[var(--color-paper)]/75">
            <Icon name="lucide:phone" class="size-4 text-[var(--color-gold)] shrink-0" aria-hidden="true" />
            <a href={`tel:${siteConfig.contact.phone}`} class="hover:text-[var(--color-gold-light)] whitespace-nowrap">
              {siteConfig.contact.phoneDisplay}
            </a>
            <a href={`tel:${siteConfig.contact.phoneSecondary}`} class="hover:text-[var(--color-gold-light)] whitespace-nowrap">
              {siteConfig.contact.phoneSecondaryDisplay}
            </a>
          </li>
        </ul>
      </div>

      <!-- Contáctanos -->
      <div>
        <p class="font-[family-name:var(--font-display)] text-[1.1rem] text-[var(--color-paper)]">
          Contáctanos
        </p>
        <form
          action="/contacto"
          method="get"
          class="mt-5"
          aria-label="Empezar conversación con CEMAD"
        >
          <label class="sr-only" for="footer-msg">Escribe tu mensaje</label>
          <div class="flex items-stretch border border-[var(--color-paper)]/30">
            <input
              id="footer-msg"
              name="mensaje"
              type="text"
              placeholder="Escribe tu mensaje"
              class="flex-1 bg-transparent border-0 px-3 py-2.5 text-sm text-[var(--color-paper)] placeholder-[var(--color-paper)]/50 focus:outline-none"
            />
            <button
              type="submit"
              class="shrink-0 w-10 inline-flex items-center justify-center bg-[var(--color-gold)] text-[var(--color-ink)] hover:bg-[var(--color-gold-light)] transition-colors focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-light)]"
              aria-label="Enviar mensaje"
            >
              <Icon name="lucide:arrow-up-right" class="size-4" aria-hidden="true" />
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-6 border-t border-[var(--color-paper)]/15 flex flex-wrap gap-4 items-center justify-between text-xs text-[var(--color-paper)]/60">
      <p>© {year} {siteConfig.name} Clinic.</p>
      <p class="flex flex-wrap items-center gap-x-3 gap-y-1">
        <span>Todos los derechos reservados.</span>
        <span aria-hidden="true">·</span>
        <span>
          Desarrollado por
          <a
            href="https://xpandex.es"
            target="_blank"
            rel="noopener external"
            class="text-[var(--color-paper)] underline-offset-2 hover:text-[var(--color-gold-light)] hover:underline"
          >
            Xpandex
          </a>
        </span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-hairline {
    background: var(--color-paper);
    opacity: 0.4;
  }
</style>
