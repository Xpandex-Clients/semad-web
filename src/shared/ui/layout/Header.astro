---
import Logo from "@shared/ui/brand/Logo.astro";
import Button from "@shared/ui/primitives/Button.astro";
import { primaryNav } from "@shared/config/navigation";
import { siteConfig } from "@shared/config/site";

interface Props {
  pathname?: string;
}

const { pathname = Astro.url.pathname } = Astro.props;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  id="site-header"
  class="site-header sticky top-0 z-40 transition-[background-color,border-color,box-shadow,color] duration-300 backdrop-blur-[2px]"
>
  <span
    aria-hidden="true"
    id="site-scroll-progress"
    class="site-scroll-progress absolute inset-x-0 top-0 h-[2px] origin-left bg-[var(--color-gold)]/70 scale-x-0"
  ></span>

  <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] py-4 grid grid-cols-[1fr_auto_1fr] items-center gap-6">
    <!-- MENU trigger -->
    <button
      type="button"
      class="menu-trigger justify-self-start inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] font-semibold focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-dark)] rounded-[var(--radius-xs)] px-2 py-1"
      aria-haspopup="dialog"
      aria-controls="site-menu-overlay"
      aria-expanded="false"
      data-menu-open
    >
      <span class="size-[14px] inline-flex flex-col justify-between" aria-hidden="true">
        <span class="block w-full h-px bg-current"></span>
        <span class="block w-full h-px bg-current"></span>
      </span>
      Menu
    </button>

    <!-- Wordmark central -->
    <a
      href="/"
      class="brand-mark justify-self-center inline-flex items-center focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-dark)] rounded-[var(--radius-xs)]"
      aria-label={`${siteConfig.name} — inicio`}
    >
      <Logo variant="principal" width={130} />
    </a>

    <!-- Phone + CTA -->
    <div class="justify-self-end hidden md:flex items-center gap-4">
      <a
        href={`tel:${siteConfig.contact.phone}`}
        class="text-[11px] uppercase tracking-[0.18em] font-semibold hover:text-[var(--color-gold-dark)]"
      >
        {siteConfig.contact.phoneDisplay}
      </a>
      <Button href="/contacto" variant="outline" size="sm">
        Reserva tu cita →
      </Button>
    </div>
  </div>
</header>

<!-- Menu overlay full-screen -->
<div
  id="site-menu-overlay"
  class="menu-overlay fixed inset-0 z-50 bg-[var(--color-paper)] text-[var(--color-ink)] opacity-0 pointer-events-none transition-opacity duration-300 ease-[var(--ease-out)]"
  role="dialog"
  aria-modal="true"
  aria-labelledby="site-menu-title"
  aria-hidden="true"
>
  <h2 id="site-menu-title" class="sr-only">Menú principal</h2>
  <div class="absolute inset-0 flex flex-col">
    <!-- close + brand mark -->
    <div class="mx-auto w-full max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] py-6 flex items-center justify-between">
      <button
        type="button"
        data-menu-close
        aria-label="Cerrar menú"
        class="size-10 rounded-full border border-[var(--color-ink)]/40 inline-flex items-center justify-center hover:bg-[var(--color-paper-soft)] focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-dark)]"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M2 2l10 10M12 2l-10 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
      </button>
      <a href="/" class="inline-flex items-center" aria-label="CEMAD inicio" data-menu-close-link>
        <Logo variant="principal" width={110} />
      </a>
      <span class="size-10" aria-hidden="true"></span>
    </div>

    <!-- nav -->
    <nav aria-label="Navegación completa" class="mt-auto mb-[10vh] mx-auto w-full max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)]">
      <ul class="flex flex-wrap items-center justify-between gap-x-6 gap-y-8 list-none p-0 m-0">
        {primaryNav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class={[
                "block font-[family-name:var(--font-display)] text-[clamp(0.85rem,1.05vw,1rem)] uppercase tracking-[0.18em] text-center leading-tight",
                "hover:text-[var(--color-gold-dark)] focus-visible:outline-2 focus-visible:outline-offset-[6px] focus-visible:outline-[var(--color-gold-dark)] rounded-[var(--radius-xs)]",
                isActive(item.href) ? "text-[var(--color-gold-dark)]" : "text-[var(--color-ink)]",
              ].join(" ")}
            >
              {item.label.split(" ").map((w, i, arr) => (
                <Fragment>
                  {w}{i < arr.length - 1 && <br />}
                </Fragment>
              ))}
            </a>
          </li>
        ))}
        <li>
          <Button href="/contacto" variant="outline" size="sm" class="uppercase tracking-[0.18em] text-[11px]">
            Reserva tu cita →
          </Button>
        </li>
      </ul>
    </nav>
  </div>
</div>

<style>
  /* Transparente sobre hero, texto blanco. La página de inicio (que tiene
     hero con bg image dark/medium) carga este estado por defecto. */
  .site-header {
    color: var(--color-paper);
    background-color: transparent;
  }
  /* Tras scroll: fondo paper sólido + texto ink + regla dorada inferior. */
  .site-header[data-bg="solid"] {
    color: var(--color-ink);
    background-color: color-mix(in oklch, var(--color-paper) 96%, transparent);
    border-bottom: 1px solid color-mix(in oklch, var(--color-gold) 30%, transparent);
    box-shadow: 0 2px 0 0 color-mix(in oklch, var(--color-gold) 14%, transparent),
                0 8px 24px -16px color-mix(in oklch, var(--color-ink) 24%, transparent);
  }
  /* En páginas interiores con hero claro, opt-in mediante data-tone="ink". */
  .site-header[data-tone="ink"] { color: var(--color-ink); }
  /* El logo dorado se mantiene; el resto del texto hereda color via currentColor. */
  .site-header .menu-trigger,
  .site-header [class*="text-[11px]"],
  .site-header [class*="uppercase"] {
    color: inherit;
  }
  .site-scroll-progress {
    transform: scaleX(var(--scroll-progress, 0));
    transition: transform 80ms linear, opacity 240ms var(--ease-out);
    opacity: 0;
  }
  .site-header[data-bg="solid"] .site-scroll-progress { opacity: 1; }
  .menu-overlay.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .site-header, .site-scroll-progress, .menu-overlay { transition: none; }
  }
</style>

<script>
  function bindHeader() {
    const header = document.getElementById("site-header");
    const bar = document.getElementById("site-scroll-progress");
    const overlay = document.getElementById("site-menu-overlay");
    const trigger = document.querySelector<HTMLButtonElement>("[data-menu-open]");
    const closeBtns = document.querySelectorAll<HTMLElement>("[data-menu-close], [data-menu-close-link]");
    if (!header) return;

    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      const max = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
      header.dataset.bg = y > 60 ? "solid" : "ghost";
      if (bar) bar.style.setProperty("--scroll-progress", String(Math.min(1, y / max)));
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    update();
    window.addEventListener("scroll", onScroll, { passive: true });

    if (overlay && trigger) {
      const open = () => {
        overlay.classList.add("is-open");
        overlay.setAttribute("aria-hidden", "false");
        trigger.setAttribute("aria-expanded", "true");
        document.documentElement.style.overflow = "hidden";
      };
      const close = () => {
        overlay.classList.remove("is-open");
        overlay.setAttribute("aria-hidden", "true");
        trigger.setAttribute("aria-expanded", "false");
        document.documentElement.style.overflow = "";
      };
      trigger.addEventListener("click", open);
      closeBtns.forEach((b) => {
        if (b.matches("[data-menu-close-link]")) {
          // link a /: cierra y deja navegar
          b.addEventListener("click", () => close());
        } else {
          b.addEventListener("click", (e) => { e.preventDefault(); close(); });
        }
      });
      overlay.addEventListener("keydown", (e) => {
        if ((e as KeyboardEvent).key === "Escape") close();
      });
      document.addEventListener("keydown", (e) => {
        if (overlay.classList.contains("is-open") && (e as KeyboardEvent).key === "Escape") close();
      });
    }
  }
  bindHeader();
  document.addEventListener("astro:page-load", bindHeader);
</script>
