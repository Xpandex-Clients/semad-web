---
import Logo from "@shared/ui/brand/Logo.astro";
import Button from "@shared/ui/primitives/Button.astro";
import MobileMenu from "@shared/ui/islands/MobileMenu.tsx";
import { primaryNav, submarcasNav, legalNav } from "@shared/config/navigation";
import { siteConfig } from "@shared/config/site";

interface Props {
  /** Para resaltar el item activo en la nav. */
  pathname?: string;
}

const { pathname = Astro.url.pathname } = Astro.props;

const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href.split("#")[0]);
---

<header
  id="site-header"
  class="site-header sticky top-0 z-40 bg-[var(--color-paper)]/95 border-b border-transparent transition-[border-color,box-shadow] duration-300 backdrop-blur-[2px]"
>
  <span
    aria-hidden="true"
    id="site-scroll-progress"
    class="site-scroll-progress absolute inset-x-0 top-0 h-[2px] origin-left bg-[var(--color-gold)]/70 scale-x-0"
  ></span>
  <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] py-3 flex items-center justify-between gap-6">
    <a
      href="/"
      class="inline-flex items-center focus-visible:outline-2 focus-visible:outline-offset-[3px] focus-visible:outline-[var(--color-gold-dark)] rounded-[var(--radius-xs)]"
      aria-label={`${siteConfig.name} — inicio`}
    >
      <Logo variant="principal" width={150} alt={`${siteConfig.name} — inicio`} />
    </a>

    <!-- Nav desktop (7 entradas planas según Figma) -->
    <nav aria-label="Principal" class="hidden lg:flex items-center gap-1">
      {primaryNav.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
          class={[
            "px-3 py-2 rounded-[var(--radius-xs)] text-[11px] uppercase tracking-[0.18em] font-semibold",
            "hover:text-[var(--color-gold-dark)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-gold-dark)]",
            isActive(item.href) ? "text-[var(--color-gold-dark)]" : "text-[var(--color-ink-soft)]",
          ].join(" ")}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA desktop outline (Figma var. B) -->
    <div class="hidden lg:flex items-center gap-2">
      <Button href="/contacto" variant="outline" size="sm">
        Reserva tu cita →
      </Button>
    </div>

    <!-- Trigger móvil (hidratado por Preact) -->
    <MobileMenu
      client:load
      primaryNav={[...primaryNav]}
      submarcas={[...submarcasNav]}
      legalNav={[...legalNav]}
      contact={{
        phone: siteConfig.contact.phone,
        phoneDisplay: siteConfig.contact.phoneDisplay,
        whatsapp: siteConfig.contact.whatsapp,
        instagram: siteConfig.contact.instagram,
      }}
    />
  </div>
</header>

<style>
  .site-header[data-scrolled="true"] {
    border-bottom-color: color-mix(in oklch, var(--color-gold) 60%, transparent);
    box-shadow: 0 2px 0 0 color-mix(in oklch, var(--color-gold) 22%, transparent),
                0 8px 24px -16px color-mix(in oklch, var(--color-ink) 30%, transparent);
    background-color: color-mix(in oklch, var(--color-paper) 98%, transparent);
  }
  .site-scroll-progress {
    transform: scaleX(var(--scroll-progress, 0));
    transition: transform 80ms linear, opacity 240ms var(--ease-out);
    opacity: 0;
  }
  .site-header[data-scrolled="true"] .site-scroll-progress { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .site-scroll-progress { transition: none; }
  }
</style>

<script>
  function bindHeaderScroll() {
    const header = document.getElementById("site-header");
    const bar = document.getElementById("site-scroll-progress");
    if (!header) return;
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      const max = Math.max(
        1,
        document.documentElement.scrollHeight - window.innerHeight,
      );
      header.dataset.scrolled = y > 120 ? "true" : "false";
      if (bar) {
        bar.style.setProperty("--scroll-progress", String(Math.min(1, y / max)));
      }
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    update();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
  bindHeaderScroll();
  document.addEventListener("astro:page-load", bindHeaderScroll);
</script>
