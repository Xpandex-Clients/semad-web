---
import "../shared/styles/globals.css";
// Body: Mona Sans (sustituta libre de Gotham — la fuente original que usa el Figma).
// Gotham es comercial (Hoefler & Co), Mona Sans fue diseñada como alternativa
// open-source con métricas y proporciones equivalentes.
import "@fontsource-variable/mona-sans/standard.css";
import "@fontsource/playfair-display/400.css";
import "@fontsource/playfair-display/500.css";
import "@fontsource/playfair-display/600.css";
import "@fontsource/playfair-display/400-italic.css";
import "@fontsource/playfair-display/500-italic.css";
import "@fontsource/corinthia/400.css";
import { ClientRouter } from "astro:transitions";
import { siteConfig } from "@shared/config/site";
import Header from "@shared/ui/layout/Header.astro";
import Footer from "@shared/ui/layout/Footer.astro";
import FloatingWhatsApp from "@shared/ui/layout/FloatingWhatsApp.astro";

interface Props {
  title?: string;
  description?: string;
  /** Oculta header/footer (404, styleguide). */
  bare?: boolean;
  /** Sobreescribe og:type por página (ej. "article" en blog post). */
  ogType?: "website" | "article" | "profile";
  /** URL absoluta de la imagen OG; cae a /og/default.jpg si se omite. */
  ogImage?: string;
  /** Alt de la imagen OG por página (describe la imagen específica). */
  ogImageAlt?: string;
  /** Bloquea indexación (stub pages, sandbox). */
  noindex?: boolean;
}

const {
  title = `${siteConfig.name} — ${siteConfig.tagline}`,
  description = siteConfig.description,
  bare = false,
  ogType = "website",
  ogImage,
  ogImageAlt,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, siteConfig.url).toString();
const ogImageUrl = ogImage ?? `${siteConfig.url}/og/default.jpg`;
const ogImageAltText = ogImageAlt ?? `${siteConfig.name} — ${siteConfig.tagline}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#bd9b5f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es-ES" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltText} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <ClientRouter />

    <!-- View Transitions extendidas (root crossfade + lift sutil). -->
    <style is:global>
      @keyframes vt-fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes vt-fade-out {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(-4px); }
      }
      ::view-transition-old(root) {
        animation: vt-fade-out 240ms var(--ease-out) both;
      }
      ::view-transition-new(root) {
        animation: vt-fade-in 380ms var(--ease-out) both;
      }
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) { animation: none; }
      }

      /* Splash screen (solo first paint sin caché de sesión). */
      .cemad-splash {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-paper);
        opacity: 1;
        transition: opacity 380ms var(--ease-out);
      }
      .cemad-splash.is-leaving {
        opacity: 0;
        pointer-events: none;
      }
      .cemad-splash[hidden] { display: none; }
      .cemad-splash__mark {
        width: clamp(220px, 28vw, 360px);
        height: auto;
        opacity: 0;
        transform: scale(0.96);
        animation: splash-in 320ms var(--ease-out) forwards;
      }
      @keyframes splash-in {
        to { opacity: 1; transform: scale(1); }
      }
      /* Spinner sutil: barra dorada al pie del wordmark */
      .cemad-splash__bar {
        position: absolute;
        bottom: calc(50% - clamp(110px, 14vw, 180px));
        width: clamp(80px, 10vw, 140px);
        height: 1px;
        background: color-mix(in oklch, var(--color-gold) 70%, transparent);
        opacity: 0;
        transform-origin: left center;
        transform: scaleX(0);
        animation: splash-bar 900ms 220ms var(--ease-in-out) forwards;
      }
      @keyframes splash-bar {
        0%   { opacity: 0; transform: scaleX(0); }
        40%  { opacity: 1; transform: scaleX(1); transform-origin: left center; }
        60%  { opacity: 1; transform: scaleX(1); transform-origin: right center; }
        100% { opacity: 0; transform: scaleX(0); transform-origin: right center; }
      }
      @media (prefers-reduced-motion: reduce) {
        .cemad-splash__mark { animation: none; opacity: 1; transform: none; }
        .cemad-splash__bar { display: none; }
      }
    </style>

    <slot name="head" />
  </head>
  <body>
    <!-- Splash screen first-paint. JS lo desmonta cuando el doc está listo. -->
    {!bare && (
      <div id="cemad-splash" class="cemad-splash" aria-hidden="true">
        <img
          src="/brand/cemad-logo.png"
          alt=""
          width="465"
          height="138"
          class="cemad-splash__mark"
        />
        <span class="cemad-splash__bar" aria-hidden="true"></span>
      </div>
    )}

    <a href="#main" class="skip-link">Saltar al contenido</a>
    {!bare && <Header />}
    <slot />
    {!bare && <Footer />}
    {!bare && <FloatingWhatsApp />}

    <script>
      // ---- Splash screen (solo first paint, una vez por sesión) ----
      function handleSplash() {
        const splash = document.getElementById("cemad-splash");
        if (!splash || splash.dataset.bound === "1") return;
        splash.dataset.bound = "1";
        const KEY = "cemad:splash";
        const seen = sessionStorage.getItem(KEY) === "1";
        if (seen) {
          splash.setAttribute("hidden", "");
          return;
        }
        sessionStorage.setItem(KEY, "1");
        const dismiss = () => {
          if (splash.classList.contains("is-leaving")) return;
          splash.classList.add("is-leaving");
          window.setTimeout(() => splash.setAttribute("hidden", ""), 420);
        };
        // Splash mínimo 900ms, máximo 1600ms (cualquier hang sale por timeout).
        window.setTimeout(dismiss, 900);
        window.setTimeout(dismiss, 1600);
      }
      handleSplash();
      document.addEventListener("astro:page-load", handleSplash);

      // ---- Image shimmer skeleton: quita la clase cuando la imagen carga ----
      function bindShimmer() {
        const wrappers = document.querySelectorAll(".img-shimmer:not(.is-loaded)");
        wrappers.forEach((w) => {
          const img = w.querySelector("img");
          if (!img) return;
          const done = () => w.classList.add("is-loaded");
          if (img.complete && img.naturalWidth > 0) done();
          else img.addEventListener("load", done, { once: true });
        });
      }
      bindShimmer();
      document.addEventListener("astro:page-load", bindShimmer);

      // ---- Hero portrait parallax (coef 0.06, solo si NO reduced-motion) ----
      function bindParallax() {
        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduced) return;
        const targets = document.querySelectorAll("[data-parallax]");
        if (!targets.length) return;
        let raf = 0;
        const apply = () => {
          const y = window.scrollY;
          targets.forEach((t) => {
            const el = t;
            const coef = parseFloat(el.dataset.parallax || "0.06");
            el.style.transform = `translate3d(0, ${(y * coef).toFixed(2)}px, 0)`;
          });
          raf = 0;
        };
        const onScroll = () => {
          if (!raf) raf = requestAnimationFrame(apply);
        };
        apply();
        window.addEventListener("scroll", onScroll, { passive: true });
      }
      bindParallax();
      document.addEventListener("astro:page-load", bindParallax);
    </script>
  </body>
</html>
