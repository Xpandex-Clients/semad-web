---
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Heading from "@shared/ui/primitives/Heading.astro";
import Badge from "@shared/ui/primitives/Badge.astro";
import Button from "@shared/ui/primitives/Button.astro";
import JsonLd from "@shared/ui/seo/JsonLd.astro";
import doctoraPortrait from "@assets/images/doctora-cevallos-portrait-legacy.jpg";
import {
  jsonLdGraph,
  physicianFullSchema,
  breadcrumbSchema,
} from "@shared/seo/schemas";
import { siteConfig } from "@shared/config/site";

const doctoraGraph = jsonLdGraph(
  physicianFullSchema(),
  breadcrumbSchema([
    { name: "Inicio", url: "/" },
    { name: "Dra. Abigail y Equipo", url: "/dra-abigail-y-equipo" },
  ]),
);
---

<Layout
  title={`Dra. Abigail Cevallos y Equipo CEMAD`}
  description={`Conoce a la Dra. Abigail Cevallos Madrid y al equipo médico de CEMAD en Valencia. Medicina estética, anti-aging y tricología bajo un mismo criterio.`}
  ogType="profile"
>
  <Fragment slot="head">
    <JsonLd data={doctoraGraph} />
  </Fragment>
  <main id="main">
    <Section tone="paper" spacing="loose">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <img
            src="/brand/cemad-isotipo.png"
            alt=""
            width="44"
            height="44"
            aria-hidden="true"
            class="mb-5 opacity-90"
          />
          <Badge tone="gold">La doctora y el equipo</Badge>
          <Heading as={1} variant="display" class="mt-3">
            {siteConfig.doctor.name}
          </Heading>
          <p class="mt-3 text-[var(--color-mute)] uppercase tracking-[0.12em] text-xs">
            {siteConfig.doctor.role}
          </p>
          <p class="mt-6 max-w-[60ch] text-[var(--color-mute)] leading-relaxed">
            Médico estético con una mirada clínica y un criterio artístico personal:
            cada plan se construye desde el diagnóstico, no desde el catálogo. Su
            trabajo prioriza preservar la identidad del paciente y obtener resultados
            naturales que se sostienen en el tiempo.
          </p>
          <p class="mt-3 max-w-[60ch] text-xs text-[var(--color-mute)]/70 italic">
            Bio profesional completa y presentación del equipo próximamente.
          </p>
          {/* TODO Fase 5 — bio doctora + equipo médico (auxiliar de tricología,
              ATC enfermería, recepción) confirmada con la cliente */}
          <Button href="/contacto" variant="primary" class="mt-8">
            Reserva una consulta
          </Button>
        </div>
        <div class="aspect-[4/5] overflow-hidden rounded-[var(--radius-lg)] bg-[var(--color-paper-soft)]">
          <Picture
            src={doctoraPortrait}
            alt={`Retrato profesional de la ${siteConfig.doctor.name}`}
            widths={[480, 768, 1024]}
            sizes="(min-width: 1024px) 480px, 90vw"
            formats={["avif", "webp"]}
            quality={82}
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover object-[center_top]"
          />
        </div>
      </div>
    </Section>
  </main>
</Layout>
