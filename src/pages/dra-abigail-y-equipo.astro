---
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Button from "@shared/ui/primitives/Button.astro";
import PageHero from "@shared/ui/layout/PageHero.astro";
import JsonLd from "@shared/ui/seo/JsonLd.astro";
import { jsonLdGraph, physicianFullSchema, breadcrumbSchema } from "@shared/seo/schemas";
import { siteConfig } from "@shared/config/site";
import heroImg from "@assets/images/page-doctora-hero.png";
import doctora2 from "@assets/images/doctora-2.png";
import doctora3 from "@assets/images/doctora-3.png";
import doctora4 from "@assets/images/doctora-4.png";
import doctoraFaceta from "@assets/images/doctora-faceta.png";
import doctoraPersonal from "@assets/images/doctora-personal.png";
import equipoImg from "@assets/images/doctora-equipo.png";

const graph = jsonLdGraph(
  physicianFullSchema(),
  breadcrumbSchema([
    { name: "Inicio", url: "/" },
    { name: "Dra. Abigail y Equipo", url: "/dra-abigail-y-equipo" },
  ]),
);
---

<Layout
  title={`${siteConfig.doctor.name} y Equipo CEMAD`}
  description="Conoce a la Dra. Abigail Cevallos y al equipo médico de CEMAD: trayectoria, filosofía y compromiso con la restauración de tu identidad."
  ogType="profile"
>
  <Fragment slot="head"><JsonLd data={graph} /></Fragment>
  <main id="main">
    <PageHero
      image={heroImg}
      alt={`Retrato editorial de la ${siteConfig.doctor.name} y equipo médico`}
      focal="center 25%"
      eyebrow="La Medicina como Vocación."
      title="La Restauración"
      subtitle="como Arte."
      intro="Conoce a la Dra. Abigail Cevallos y al equipo médico que ha hecho de la medicina personalizada, el rigor científico y la empatía profunda su razón de ser."
    />

    <!-- DRA. ABIGAIL (Figma invierte: texto izq, foto der) =========== -->
    <Section tone="paper" spacing="loose">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start lg:[&>*:first-child]:order-2">
        <div class="aspect-[3/4] overflow-hidden rounded-none shadow-[var(--shadow-card)]">
          <Picture
            src={doctora2}
            alt="Dra. Abigail Cevallos en consulta"
            widths={[480, 768, 1024]}
            sizes="(min-width: 1024px) 540px, 92vw"
            formats={["avif", "webp"]}
            quality={80}
            class="h-full w-full object-cover"
          />
        </div>
        <div>
          <p class="text-[0.7rem] tracking-[0.22em] uppercase text-[var(--color-gold-dark)] font-medium">
            Fundadora · Directora Médica
          </p>
          <h2 class="mt-3 font-[family-name:var(--font-display)] font-normal text-[clamp(2.5rem,5vw,4rem)] leading-[1.02] text-[var(--color-ink)]">
            <span class="block">Dra.</span>
            <em class="block not-italic italic text-[var(--color-gold)]">Abigail Cevallos</em>
          </h2>
          <div class="mt-5 w-[80px] h-[2px] bg-[var(--color-gold)]"></div>
          <p class="mt-6 text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
            La Dra. Abigail Cevallos no eligió la tricología y la medicina
            estética por casualidad. Su propia experiencia con la alopecia areata
            la llevó a comprender profundamente el impacto emocional de la
            pérdida capilar y la necesidad urgente de un abordaje médico que
            fuera más allá de lo superficial. Esa experiencia personal la
            transformó en una misión profesional: crear un modelo de medicina
            que honrara la identidad del paciente, comprendiera las causas raíz
            y acompañara con rigor científico y empatía profunda.
          </p>
        </div>
      </div>
    </Section>

    <!-- TRAYECTORIA / FILOSOFÍA / COMPROMISO -->
    <Section tone="paper-soft" spacing="loose">
      <div class="max-w-4xl mx-auto space-y-12">
        <div class="grid md:grid-cols-[0.6fr_1fr] gap-8 items-start">
          <div class="aspect-[3/4] overflow-hidden rounded-none">
            <Picture src={doctora3} alt="Dra. Abigail" widths={[400, 600]} sizes="(min-width: 768px) 320px, 92vw" formats={["avif","webp"]} quality={80} class="h-full w-full object-cover" />
          </div>
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-[1.75rem] text-[var(--color-ink)]">Su Trayectoria</h3>
            <ul class="mt-4 space-y-2 list-none p-0 text-[var(--color-mute)]">
              <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Más de 10 años de experiencia clínica especializada.</li>
              <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Más de 1.000 cirugías capilares con resultados naturales.</li>
              <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>30 cursos de especialización en tricología, medicina estética y medicina integrativa.</li>
              <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>12 másteres universitarios en áreas de medicina avanzada.</li>
              <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Creadora del Método Kintsugi: sistema exclusivo de medicina personalizada.</li>
              <li class="flex gap-3"><span class="mt-2 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Pionera en Medicina de Precisión con Alma en Valencia.</li>
            </ul>
          </div>
        </div>

        <div class="grid md:grid-cols-[1fr_0.6fr] gap-8 items-start">
          <div>
            <p class="text-[0.7rem] tracking-[0.18em] uppercase text-[var(--color-gold-dark)] font-medium">
              Su Filosofía
            </p>
            <div class="mt-4 bg-[var(--color-cream)]/40 border-l-4 border-[var(--color-gold)] p-7 lg:p-8 relative">
              <span aria-hidden="true" class="absolute top-2 left-3 font-[family-name:var(--font-display)] italic text-[3rem] leading-none text-[var(--color-gold)]/70">
                &ldquo;
              </span>
              <p class="pl-7 italic text-[var(--color-ink-soft)] leading-relaxed text-[1.0625rem]">
                No transformar, sino revelar. No estandarizar, sino honrar la
                identidad única de cada paciente. Cada persona que entra en CEMAD
                merece ser comprendida en su totalidad: su historia, sus causas
                internas, sus miedos y sus sueños. Solo desde esa comprensión
                profunda podemos diseñar un plan que realmente tenga sentido.
              </p>
            </div>
            <p class="mt-10 text-[0.7rem] tracking-[0.18em] uppercase text-[var(--color-gold-dark)] font-medium">
              Su Compromiso
            </p>
            <h3 class="mt-3 font-[family-name:var(--font-display)] italic text-[1.5rem] text-[var(--color-ink)] leading-tight">
              Lidera personalmente cada diagnóstico
            </h3>
            <p class="mt-4 text-[var(--color-mute)] leading-relaxed">
              La Dra. Cevallos diseña en persona cada plan terapéutico en CEMAD.
              No delega la parte más importante: comprender a la persona detrás
              del paciente.
            </p>
          </div>
          <div class="aspect-[3/4] overflow-hidden rounded-none">
            <Picture src={doctora4} alt="Dra. Abigail consultando" widths={[400, 600]} sizes="(min-width: 768px) 320px, 92vw" formats={["avif","webp"]} quality={80} class="h-full w-full object-cover" />
          </div>
        </div>
      </div>
    </Section>

    <!-- FACETA PERSONAL -->
    <Section tone="paper" spacing="loose">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="aspect-[3/4] overflow-hidden rounded-none">
          <Picture src={doctoraFaceta} alt="Faceta personal de la doctora" widths={[480, 768, 1024]} sizes="(min-width: 1024px) 540px, 92vw" formats={["avif","webp"]} quality={80} class="h-full w-full object-cover" />
        </div>
        <div>
          <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-ink)] leading-[1.05]">
            <span class="block">Faceta</span>
            <span class="block text-[var(--color-gold)] italic">Personal</span>
          </h2>
          <p class="mt-6 text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
            "Más allá de la consulta, la Dra. Abigail es una mujer que comprende
            el valor de la identidad porque tuvo que luchar por la suya. Esa
            empatía nacida de la experiencia personal es lo que hace de CEMAD un
            lugar donde los pacientes no solo reciben tratamiento, sino
            comprensión y respaldo profundo."
          </p>
        </div>
      </div>
    </Section>

    <!-- EQUIPO -->
    <Section tone="paper-soft" spacing="loose">
      <div class="max-w-4xl mx-auto">
        <div class="aspect-[21/9] overflow-hidden rounded-none mb-10">
          <Picture src={equipoImg} alt="Equipo CEMAD" widths={[768, 1024, 1440]} sizes="(min-width: 1024px) 1024px, 92vw" formats={["avif","webp"]} quality={78} class="h-full w-full object-cover" />
        </div>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)]">
          <span class="block text-[var(--color-ink)]">El Equipo</span>
          <span class="block text-[var(--color-gold)] italic">CEMAD</span>
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
        <p class="mt-6 font-[family-name:var(--font-display)] italic text-2xl text-[var(--color-ink)]">
          Un Equipo Comprometido con tu Bienestar Integral
        </p>
        <p class="mt-4 text-[var(--color-mute)] leading-relaxed max-w-[68ch]">
          Cada miembro del equipo CEMAD comparte la misma filosofía: la medicina
          debe ser personalizada, empática y excelente. Desde el equipo médico
          hasta el personal de atención, todos están formados para acompañarte
          con calidez profesional en cada etapa de tu proceso.
        </p>
        <h3 class="mt-12 font-[family-name:var(--font-display)] text-2xl text-[var(--color-ink)]">
          Respaldados por la Excelencia Científica
        </h3>
        <ul class="mt-6 grid sm:grid-cols-2 gap-3 list-none p-0 text-sm text-[var(--color-mute)]">
          <li class="flex gap-3"><span class="mt-1.5 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Miembro de la Sociedad Española de Medicina Estética (SEME).</li>
          <li class="flex gap-3"><span class="mt-1.5 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Certificación en Cirugía Capilar FUE/DHI.</li>
          <li class="flex gap-3"><span class="mt-1.5 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Certificación en Tricoscopia Avanzada.</li>
          <li class="flex gap-3"><span class="mt-1.5 size-1.5 rounded-full bg-[var(--color-gold)] shrink-0"></span>Acreditación en Medicina Tradicional China.</li>
        </ul>
      </div>
    </Section>

    <!-- CTA -->
    <Section tone="ink" spacing="loose">
      <div class="text-center max-w-2xl mx-auto text-[var(--color-paper)]">
        <img src="/brand/cemad-logo-white.png" alt="" aria-hidden="true" width="160" class="mx-auto mb-6 opacity-95" />
        <h2 class="font-[family-name:var(--font-display)] font-light text-[clamp(2.25rem,4.8vw,3.5rem)] leading-[1.1]">
          Conoce al equipo
          <em class="block mt-2 not-italic italic text-[var(--color-gold)] font-normal">en consulta personal</em>
        </h2>
        <p class="mt-6 text-[var(--color-paper)]/85">
          La primera consulta con la Dra. Cevallos es una conversación, no una venta.
        </p>
        <div class="mt-10">
          <Button href="/contacto" variant="primary" size="lg">Reserva tu Auditoría de Imagen →</Button>
        </div>
      </div>
    </Section>
  </main>
</Layout>
