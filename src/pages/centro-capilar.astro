---
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Button from "@shared/ui/primitives/Button.astro";
import PageHero from "@shared/ui/layout/PageHero.astro";
import heroImg from "@assets/images/page-capilar-hero.png";
import pilar1 from "@assets/images/capilar-pilar-1.png";
import pilar2 from "@assets/images/capilar-pilar-2.png";
import pilar3 from "@assets/images/capilar-pilar-3.png";

const pilares = [
  {
    n: 1,
    title: "Diagnóstico Tricológico Avanzado",
    body:
      "Trichoscan digital, historia clínica completa y, según el caso, estudio hormonal o genético. Identificamos la causa real de tu pérdida capilar antes de tratarla.",
    img: pilar1,
  },
  {
    n: 2,
    title: "Tratamientos Médicos Personalizados",
    body:
      "Plan médico 100% personalizado: PRP, mesoterapia, fármacos dirigidos, programas Dra. AbiCapilar (mujeres), Control Androgenético, Reparación Post-Parto y protocolos para alopecias específicas (areata, frontal fibrosante, cicatriciales, tracción).",
    img: pilar2,
  },
  {
    n: 3,
    title: "Cirugía Capilar de Precisión",
    body:
      "Extracción individual de folículos sin cicatriz lineal (FUE/DHI), implantación precisa controlando ángulo y profundidad, recuperación rápida (5-7 días), resultados naturales permanentes.",
    img: pilar3,
  },
];
---

<Layout
  title="Centro de Tricología y Cirugía Capilar — CEMAD"
  description="Centro Capilar de CEMAD: diagnóstico tricológico avanzado, tratamientos médicos personalizados y cirugía de implante FUE/DHI con la Dra. Abigail Cevallos en Valencia."
>
  <main id="main">
    <PageHero
      image={heroImg}
      alt="Centro Capilar CEMAD — composición editorial"
      focal="center 35%"
      eyebrow="Centro de Excelencia en"
      title="Tricología:"
      subtitle="La Ciencia y el Arte de un Cabello Sano y Fuerte"
    />

    <!-- INTRO -->
    <Section tone="paper-soft" spacing="default" width="narrow">
      <div class="max-w-[68ch] mx-auto">
        <p class="text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
          En CEMAD comprendemos profundamente el impacto emocional de la
          alopecia. La <strong class="text-[var(--color-ink)] font-medium">Dra. Abigail Cevallos vivió en primera persona la alopecia areata</strong>,
          y esa experiencia transformó su enfoque: la pérdida capilar no es solo
          un problema estético, es una crisis de identidad que merece un
          abordaje médico integral, empático y profundo.
        </p>
        <p class="mt-6 font-[family-name:var(--font-display)] italic text-[var(--color-ink)] text-2xl leading-snug">
          No tratamos "calvicie". Restauramos armonía capilar.
        </p>
        <p class="mt-4 text-[var(--color-mute)] leading-relaxed">
          No aplicamos protocolos estándar. Diseñamos estrategias personalizadas
          que abordan la causa raíz de tu alopecia —hormonal, nutricional,
          autoinmune, genética o por estrés— y te acompañamos en cada fase
          hasta que vuelvas a reconocerte con orgullo.
        </p>
      </div>
    </Section>

    <!-- 3 PILARES (Figma 05-08): hero full-bleed + cuerpo editorial debajo -->
    <Section tone="paper" spacing="default">
      <div class="mb-8 max-w-3xl">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] leading-[1.05]">
          <span class="block text-[var(--color-ink)]">Los 3 pilares del</span>
          <em class="block not-italic italic text-[var(--color-gold)]">centro capilar</em>
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
      </div>
    </Section>
    {pilares.map((p, i) => (
      <Fragment>
        <section class="relative isolate overflow-hidden">
          <div class="relative aspect-[16/9] lg:aspect-[16/7] w-full overflow-hidden">
            <Picture src={p.img} alt={p.title} widths={[768, 1024, 1440, 1920]} sizes="100vw" formats={["avif","webp"]} quality={80} loading="eager" class="absolute inset-0 h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-ink)]/75 via-[var(--color-ink)]/35 to-transparent"></div>
            <div class="absolute inset-0 flex items-end">
              <div class="mx-auto max-w-[var(--container-wide)] w-full px-[clamp(1rem,4vw,2rem)] py-12 text-[var(--color-paper)]">
                <span class="text-[11px] uppercase tracking-[0.22em] font-semibold text-[var(--color-gold)]">
                  Pilar {p.n}
                </span>
                <h3 class="mt-3 font-[family-name:var(--font-display)] font-light text-[clamp(2.25rem,5vw,4rem)] leading-[1.05] max-w-3xl">
                  {p.title}
                </h3>
              </div>
            </div>
          </div>
        </section>
        <Section tone={i % 2 === 0 ? "paper-soft" : "paper"} spacing="default">
          <p class="text-[var(--color-mute)] leading-relaxed text-[1.0625rem] max-w-[68ch] mx-auto">
            {p.body}
          </p>
          {p.n === 2 && (
            <Fragment>
              <!-- Arsenal terapéutico 2x2 (Figma 06-07) -->
              <ul class="mt-12 grid md:grid-cols-2 gap-5 list-none p-0 max-w-5xl mx-auto">
                <li class="bg-[var(--color-paper)] p-7 rounded-[var(--radius-sm)] border-l-4 border-[var(--color-gold)]">
                  <p class="font-[family-name:var(--font-display)] italic text-[var(--color-gold-dark)] text-sm uppercase tracking-[0.18em]">Mesoterapia</p>
                  <p class="mt-2 font-[family-name:var(--font-display)] text-[1.25rem] text-[var(--color-ink)] leading-tight">Activos directos al folículo</p>
                  <p class="mt-3 text-sm text-[var(--color-mute)] leading-relaxed">Microinyecciones de vitaminas, aminoácidos y factores tricoespecíficos para nutrir el cuero cabelludo y estimular el ciclo capilar.</p>
                </li>
                <li class="bg-[var(--color-cream)]/35 p-7 rounded-[var(--radius-sm)] border-l-4 border-[var(--color-gold)]">
                  <p class="font-[family-name:var(--font-display)] italic text-[var(--color-gold-dark)] text-sm uppercase tracking-[0.18em]">PRP capilar</p>
                  <p class="mt-2 font-[family-name:var(--font-display)] text-[1.25rem] text-[var(--color-ink)] leading-tight">Plasma rico en plaquetas</p>
                  <p class="mt-3 text-sm text-[var(--color-mute)] leading-relaxed">Bioestimulación con tu propio plasma. Frena la caída y reactiva folículos miniaturizados sin sustancias externas.</p>
                </li>
                <li class="bg-[var(--color-cream)]/35 p-7 rounded-[var(--radius-sm)] border-l-4 border-[var(--color-gold)]">
                  <p class="font-[family-name:var(--font-display)] italic text-[var(--color-gold-dark)] text-sm uppercase tracking-[0.18em]">Farmacológicos</p>
                  <p class="mt-2 font-[family-name:var(--font-display)] text-[1.25rem] text-[var(--color-ink)] leading-tight">Protocolos dirigidos</p>
                  <p class="mt-3 text-sm text-[var(--color-mute)] leading-relaxed">Minoxidil, antiandrógenos, finasterida tópica y otros activos según diagnóstico. Pauta médica supervisada.</p>
                </li>
                <li class="bg-[var(--color-paper)] p-7 rounded-[var(--radius-sm)] border-l-4 border-[var(--color-gold)]">
                  <p class="font-[family-name:var(--font-display)] italic text-[var(--color-gold-dark)] text-sm uppercase tracking-[0.18em]">Bioestimulación</p>
                  <p class="mt-2 font-[family-name:var(--font-display)] text-[1.25rem] text-[var(--color-ink)] leading-tight">Factores de crecimiento</p>
                  <p class="mt-3 text-sm text-[var(--color-mute)] leading-relaxed">Exosomas, péptidos biomiméticos y bioactivadores capilares para regeneración profunda.</p>
                </li>
              </ul>
              <!-- Programas específicos (Figma 08) -->
              <dl class="mt-14 max-w-5xl mx-auto space-y-0">
                {[
                  { name: "Programa Dra. AbiCapilar (Mujeres)", body: "Diseñado para alopecia femenina por causa hormonal o estrés. Combina diagnóstico hormonal completo + mesoterapia personalizada + acompañamiento durante 12 meses." },
                  { name: "Programa Control Androgenético", body: "Para alopecia androgenética en hombres y mujeres. Protocolo farmacológico + bioestimulación + revisión trimestral." },
                  { name: "Programa Reparación Capilar", body: "Para alopecia areata, cicatriciales y por tracción. Tratamiento médico + plan de regeneración + apoyo emocional cuando hace falta." },
                  { name: "Programa Mantenimiento", body: "Postinjerto o post-tratamiento. Revisión cada 3-6 meses + bioestimulación de refuerzo + ajustes médicos según evolución." },
                ].map((prog) => (
                  <div class="grid md:grid-cols-[280px_1fr] gap-4 md:gap-10 py-6 border-t border-[var(--color-paper-warm)]">
                    <dt class="font-[family-name:var(--font-display)] italic text-[var(--color-ink)] text-[1.05rem] leading-tight">
                      {prog.name}
                    </dt>
                    <dd class="text-sm text-[var(--color-mute)] leading-relaxed">{prog.body}</dd>
                  </div>
                ))}
              </dl>
            </Fragment>
          )}
        </Section>
      </Fragment>
    ))}

    <!-- TÉCNICAS QUE DOMINAMOS (Figma 11-12) ====================== -->
    <Section tone="paper-soft" spacing="loose">
      <div class="max-w-3xl mb-10">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] text-[var(--color-ink)] leading-[1.05]">
          <em class="block not-italic italic text-[var(--color-gold)]">Técnicas que dominamos</em>
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
        <p class="mt-6 text-[var(--color-mute)] leading-relaxed">
          Combinamos las técnicas quirúrgicas más reconocidas internacionalmente
          con un criterio artístico personal: cada injerto es diseñado para
          tu línea frontal, densidad y dirección natural del cabello.
        </p>
      </div>
      <ul class="grid md:grid-cols-2 gap-6 list-none p-0">
        <li class="bg-[var(--color-paper)] p-10 lg:p-12 rounded-[var(--radius-sm)] min-h-[320px] border-l-4 border-[var(--color-gold)]">
          <p class="font-[family-name:var(--font-display)] text-[2rem] text-[var(--color-ink)] leading-none">FUE</p>
          <p class="mt-2 font-[family-name:var(--font-display)] italic text-base text-[var(--color-gold-dark)]">Follicular Unit Extraction</p>
          <p class="mt-6 text-[15px] text-[var(--color-mute)] leading-relaxed">
            Extracción individual de folículos sin cicatriz lineal, implantación
            precisa controlando ángulo y profundidad, recuperación rápida (5-7 días),
            resultados naturales y permanentes.
          </p>
        </li>
        <li class="bg-[var(--color-cream)]/35 p-10 lg:p-12 rounded-[var(--radius-sm)] min-h-[320px] border-l-4 border-[var(--color-gold)]">
          <p class="font-[family-name:var(--font-display)] text-[2rem] text-[var(--color-ink)] leading-none">DHI</p>
          <p class="mt-2 font-[family-name:var(--font-display)] italic text-base text-[var(--color-gold-dark)]">Direct Hair Implantation</p>
          <p class="mt-6 text-[15px] text-[var(--color-mute)] leading-relaxed">
            Implante directo con <em>implanter pen</em>: máxima precisión en
            zonas visibles (entradas, coronilla, líneas frontales). Sin necesidad
            de apertura previa de canales.
          </p>
        </li>
        <li class="bg-[var(--color-cream)]/35 p-10 lg:p-12 rounded-[var(--radius-sm)] min-h-[320px] border-l-4 border-[var(--color-gold)]">
          <p class="font-[family-name:var(--font-display)] text-[1.5rem] text-[var(--color-ink)] leading-tight">Cirugía de Reparación</p>
          <p class="mt-2 font-[family-name:var(--font-display)] italic text-base text-[var(--color-gold-dark)]">Restorative Surgery</p>
          <p class="mt-6 text-[15px] text-[var(--color-mute)] leading-relaxed">
            Corrección de injertos previos mal diseñados, líneas frontales
            antinaturales o densidad insuficiente. Recuperamos la naturalidad
            perdida.
          </p>
        </li>
        <li class="bg-[var(--color-paper)] p-10 lg:p-12 rounded-[var(--radius-sm)] min-h-[320px] border-l-4 border-[var(--color-gold)]">
          <p class="font-[family-name:var(--font-display)] text-[1.5rem] text-[var(--color-ink)] leading-tight">Diseño de Línea Frontal</p>
          <p class="mt-2 font-[family-name:var(--font-display)] italic text-base text-[var(--color-gold-dark)]">Hairline Design</p>
          <p class="mt-6 text-[15px] text-[var(--color-mute)] leading-relaxed">
            Estudio facial individualizado para diseñar la línea frontal con
            asimetría natural, irregularidad estética y orientación folicular
            coherente con tu rostro.
          </p>
        </li>
      </ul>

      <!-- Callout dorado resultados esperables -->
      <div class="mt-10 bg-[var(--color-gold)]/95 text-[var(--color-ink)] p-8 lg:p-10 rounded-[var(--radius-sm)] shadow-[var(--shadow-card)] grid md:grid-cols-[auto_1fr] gap-6 lg:gap-10 items-center">
        <p class="font-[family-name:var(--font-display)] italic text-[var(--color-paper)] text-xl">
          Resultados<br/>esperables
        </p>
        <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-2 text-sm text-[var(--color-paper)]/95 list-none p-0">
          <li>· Primeros signos de crecimiento: 3-4 meses</li>
          <li>· Resultado visible: 6 meses</li>
          <li>· Resultado final: 12 meses</li>
          <li>· Permanencia: de por vida</li>
        </ul>
      </div>
    </Section>

    <!-- TIPOS DE ALOPECIA (Figma 13-15) ============================ -->
    <Section tone="paper" spacing="loose">
      <div class="max-w-3xl mb-10">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-ink)] leading-[1.05]">
          <span class="block">Tipos de alopecia</span>
          <em class="block not-italic italic text-[var(--color-gold)]">que tratamos</em>
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
        <p class="mt-6 font-[family-name:var(--font-display)] italic text-[var(--color-ink)] text-xl leading-snug">
          Cada alopecia tiene una causa. Cada causa requiere un tratamiento diferente.
        </p>
        <p class="mt-4 text-[var(--color-mute)] leading-relaxed">
          En CEMAD no tratamos "caída de cabello" de forma genérica. Identificamos
          el tipo específico de alopecia que estás experimentando y diseñamos el
          protocolo médico correspondiente.
        </p>
      </div>
      <ol class="grid md:grid-cols-2 gap-6 list-none p-0">
        {[
          { n: "01", title: "Alopecia Androgenética (Genética)", body: "La más común en hombres y mujeres. Pérdida progresiva por factores genéticos y hormonales. Tratamiento médico personalizado y cirugía de precisión cuando es necesario." },
          { n: "02", title: "Alopecia Areata (Autoinmune)", body: "Pérdida en parches por ataque del sistema inmune. Abordaje integral con tratamiento médico, manejo del estrés y acompañamiento emocional." },
          { n: "03", title: "Alopecia Frontal Fibrosante", body: "Retroceso de la línea frontal con cicatrización. Diagnóstico temprano y tratamiento especializado para frenar progresión." },
          { n: "04", title: "Efluvio Telógeno", body: "Caída difusa por estrés, postparto, cirugías o cambios hormonales. Identificación del detonante y restauración del ciclo capilar." },
          { n: "05", title: "Alopecia por Déficits Nutricionales", body: "Caída por falta de hierro, vitaminas o proteínas. Analítica completa y suplementación dirigida." },
          { n: "06", title: "Alopecia por Tracción", body: "Pérdida por tensión mecánica (peinados apretados, extensiones). Cambio de hábitos y tratamiento regenerativo." },
        ].map((t) => (
          <li class="grid grid-cols-[auto_1fr] gap-5 items-start border-t border-[var(--color-paper-warm)] pt-6">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-gold)] text-2xl leading-none">
              {t.n}
            </p>
            <div>
              <p class="font-[family-name:var(--font-display)] italic text-[var(--color-ink)] text-lg leading-tight">
                {t.title}
              </p>
              <p class="mt-3 text-sm text-[var(--color-mute)] leading-relaxed">
                {t.body}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </Section>

    <!-- CTA -->
    <Section tone="ink" spacing="loose">
      <div class="text-center max-w-2xl mx-auto text-[var(--color-paper)]">
        <img src="/brand/cemad-logo-white.png" alt="" aria-hidden="true" width="160" class="mx-auto mb-6 opacity-95" />
        <h2 class="font-[family-name:var(--font-display)] font-light text-[clamp(2.25rem,4.8vw,3.5rem)] leading-[1.1]">
          Empieza por tu
          <em class="block mt-2 not-italic italic text-[var(--color-gold)] font-normal">diagnóstico capilar</em>
        </h2>
        <p class="mt-6 text-[var(--color-paper)]/85">Trichoscan + valoración con la doctora.</p>
        <div class="mt-10">
          <Button href="/contacto" variant="primary" size="lg">Reserva tu Auditoría de Imagen →</Button>
        </div>
      </div>
    </Section>
  </main>
</Layout>
