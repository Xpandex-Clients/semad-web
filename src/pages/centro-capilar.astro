---
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Heading from "@shared/ui/primitives/Heading.astro";
import Badge from "@shared/ui/primitives/Badge.astro";
import Button from "@shared/ui/primitives/Button.astro";
---

<Layout
  title="Centro de Tricología y Cirugía Capilar — CEMAD"
  description="Centro Capilar de CEMAD: diagnóstico tricológico, cirugía de implante FUE, regeneración con PRP, mesoterapia y tratamiento médico capilar en Valencia."
>
  <main id="main">
    <Section tone="paper" spacing="loose">
      <div class="text-center max-w-3xl mx-auto">
        <Badge tone="gold">Centro Capilar</Badge>
        <Heading as={1} variant="display" align="center" class="mt-3">
          Centro de Tricología y <em class="not-italic font-[family-name:var(--font-script)] text-[1.2em] text-[var(--color-gold)] font-normal">Cirugía Capilar</em>
        </Heading>
        <p class="mt-6 text-lg text-[var(--color-mute)] leading-relaxed">
          Salud capilar abordada desde la causa: diagnóstico médico, tratamientos
          regenerativos y, cuando está indicado, injerto capilar mediante técnicas
          de micropunción.
        </p>
      </div>
    </Section>

    <Section tone="paper-soft" spacing="default" width="narrow">
      <div class="text-center">
        <Badge tone="gold">En construcción</Badge>
        <Heading as={2} visual={3} class="mt-3">
          Página en preparación
        </Heading>
        <p class="mt-3 text-[var(--color-mute)]">
          Contenido detallado en preparación: tratamientos, diagnóstico tricológico
          y proceso de injerto.
        </p>
        <Button href="/contacto" variant="primary" class="mt-6">
          Pedir diagnóstico capilar
        </Button>
      </div>
    </Section>
  </main>
</Layout>
