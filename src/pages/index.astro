---
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Heading from "@shared/ui/primitives/Heading.astro";
import Button from "@shared/ui/primitives/Button.astro";
import Card from "@shared/ui/primitives/Card.astro";
import Badge from "@shared/ui/primitives/Badge.astro";
import Logo from "@shared/ui/brand/Logo.astro";
import { siteConfig } from "@shared/config/site";
import { services } from "@shared/config/services";
---

<Layout>
  <main id="main">
    <!-- HERO -->
    <Section tone="paper" spacing="loose">
      <div class="text-center max-w-3xl mx-auto">
        <Logo variant="principal" width={220} class="mx-auto mb-8" />
        <Heading as={1} variant="display" align="center">
          Donde la ciencia y el arte se unen para revelar
          <span class="block mt-2 font-[family-name:var(--font-script)] text-[1.1em] text-[var(--color-gold-dark)]">
            Tu Mejor Versión
          </span>
        </Heading>
        <p class="mt-6 text-lg text-[var(--color-mute)] max-w-[60ch] mx-auto">
          {siteConfig.description}
        </p>
        <div class="mt-10 flex gap-3 justify-center flex-wrap">
          <Button href="/contacto" variant="primary" size="lg">
            Reserva tu primera consulta
          </Button>
          <Button href="#especialidades" variant="ghost" size="lg">
            Ver especialidades
          </Button>
        </div>
      </div>
    </Section>

    <!-- SUBMARCAS -->
    <Section id="especialidades" tone="paper-soft" spacing="default">
      <div class="text-center mb-10">
        <Badge tone="gold">Especialidades</Badge>
        <Heading as={2} visual={2} align="center" class="mt-3">
          Cinco caminos hacia <em class="not-italic font-[family-name:var(--font-script)] text-[1.2em] text-[var(--color-gold-dark)]">Tu Mejor Versión</em>
        </Heading>
      </div>
      <ul class="grid gap-6 grid-cols-[repeat(auto-fit,minmax(260px,1fr))] list-none p-0 m-0">
        {services.map((s) => (
          <Card as="li" variant="elevated" accent={s.color} href={`/${s.slug}`}>
            <Badge accent={s.color}>{s.name}</Badge>
            <Heading as={3} visual={3} class="mt-3">{s.fullName}</Heading>
            <p class="font-[family-name:var(--font-script)] text-2xl mt-1" style={`color:${s.ariaColor}`}>
              {s.shortClaim}
            </p>
            <p class="text-[var(--color-mute)] mt-2 text-sm">{s.longClaim}</p>
            <span class="block mt-4 text-[var(--color-ink)] font-medium border-b border-current pb-0.5 w-fit">
              Descubrir →
            </span>
          </Card>
        ))}
      </ul>
    </Section>

    <!-- DOCTORA TEASER (placeholder fase 5) -->
    <Section tone="paper" spacing="default">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <Badge tone="gold">La doctora</Badge>
          <Heading as={2} visual={2} class="mt-3">
            La medicina estética es una ciencia de detalles.
          </Heading>
          <p class="mt-4 text-[var(--color-mute)]">
            CEMAD es la clínica de la <strong>{siteConfig.doctor.name}</strong>,
            especialista en {siteConfig.doctor.role.toLowerCase()} en el centro de Valencia.
            <em class="text-[var(--color-mute)]">
              [TODO: bio profesional confirmada por la cliente]
            </em>
          </p>
          <Button href="/dra-abigail-cevallos" variant="outline" class="mt-6">
            Conoce a la doctora
          </Button>
        </div>
        <div class="aspect-[4/5] bg-[var(--color-paper-soft)] rounded-[var(--radius-lg)] flex items-center justify-center text-[var(--color-mute)] text-sm">
          [Foto de la Dra. Cevallos · pendiente de cliente]
        </div>
      </div>
    </Section>

    <!-- CTA principal antes del footer -->
    <Section tone="gold" spacing="default">
      <div class="text-center max-w-2xl mx-auto">
        <Heading as={2} visual={2} tone="invert" align="center">
          Empieza por una conversación.
        </Heading>
        <p class="mt-4 text-[var(--color-paper)]/90">
          La primera consulta con la {siteConfig.doctor.name} es donde
          empezamos a definir tu plan personalizado.
        </p>
        <div class="mt-8 flex gap-3 justify-center flex-wrap">
          <Button href="/contacto" variant="submarca" accent="var(--color-paper)" accentText="var(--color-gold-dark)" size="lg">
            Reservar consulta
          </Button>
          <Button
            href={`https://wa.me/${siteConfig.contact.whatsapp.replace(/[^0-9]/g, '')}`}
            variant="outline"
            size="lg"
            target="_blank"
            class="text-[var(--color-paper)] border-[var(--color-paper)]/40 hover:border-[var(--color-paper)] hover:bg-white/10"
          >
            WhatsApp
          </Button>
        </div>
      </div>
    </Section>
  </main>
</Layout>
