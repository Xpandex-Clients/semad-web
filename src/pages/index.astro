---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "@shared/config/site";
import { services } from "@shared/config/services";
---

<Layout>
  <main id="main">
    <section class="hero">
      <p class="eyebrow">{siteConfig.legalName}</p>
      <h1>
        Donde la ciencia y el arte se unen para revelar
        <em class="script">Tu Mejor Versión</em>
      </h1>
      <p class="lead">{siteConfig.description}</p>
      <div class="ctas">
        <a class="btn primary" href="/contacto">Reserva tu primera consulta</a>
        <a class="btn ghost" href="#especialidades">Ver especialidades</a>
      </div>
    </section>

    <section id="especialidades" class="services">
      <h2>Nuestras especialidades</h2>
      <ul class="grid">
        {services.map((s) => (
          <li class="card" style={`--accent:${s.color}`}>
            <span class="accent" aria-hidden="true"></span>
            <h3>{s.fullName}</h3>
            <p class="claim script">{s.shortClaim}</p>
            <p>{s.longClaim}</p>
            <a class="link" href={`/${s.slug}`}>Descubrir &rarr;</a>
          </li>
        ))}
      </ul>
    </section>

    <footer class="footer">
      <p>
        <strong>{siteConfig.name}</strong> ·
        {siteConfig.address.street}, {siteConfig.address.locality} ·
        <a href={`tel:${siteConfig.contact.phone}`}>{siteConfig.contact.phoneDisplay}</a>
        · <a href={siteConfig.contact.instagram}>{siteConfig.contact.instagramHandle}</a>
      </p>
      <p class="microcopy">
        Página inicial provisional — el diseño definitivo se construye en las fases 2-7 del checklist.
      </p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: var(--container-default);
    margin-inline: auto;
    padding-inline: clamp(1rem, 4vw, 2rem);
  }
  .hero {
    padding-block: clamp(3rem, 10vw, 7rem);
    text-align: center;
  }
  .eyebrow {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gold-dark);
    margin-bottom: var(--spacing-4);
  }
  h1 {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    max-width: 22ch;
    margin-inline: auto;
  }
  .script {
    font-family: var(--font-script);
    font-style: normal;
    color: var(--color-gold-dark);
    font-size: 1.1em;
  }
  .lead {
    max-width: 60ch;
    margin: var(--spacing-6) auto 0;
    color: var(--color-mute);
  }
  .ctas {
    display: flex;
    gap: var(--spacing-4);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--spacing-8);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-weight: 500;
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-out),
                background var(--duration-base) var(--ease-out);
  }
  .btn.primary {
    background: var(--color-gold);
    color: var(--color-paper);
  }
  .btn.primary:hover { background: var(--color-gold-dark); }
  .btn.ghost {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-mute);
  }
  .btn.ghost:hover { border-color: var(--color-ink); }

  .services {
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .services h2 {
    font-size: var(--text-4xl);
    text-align: center;
    margin-bottom: var(--spacing-12);
  }
  .grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-6);
  }
  .card {
    background: var(--color-paper-soft);
    border-radius: var(--radius-md);
    padding: var(--spacing-6);
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  .accent {
    position: absolute; inset: 0 0 auto 0;
    height: 4px; background: var(--accent);
  }
  .card h3 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--spacing-2);
  }
  .card .claim {
    color: var(--accent);
    font-size: var(--text-xl);
    margin: 0 0 var(--spacing-3);
  }
  .card p { color: var(--color-mute); margin: 0; }
  .link {
    display: inline-block;
    margin-top: var(--spacing-4);
    color: var(--color-ink);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  .footer {
    text-align: center;
    padding-block: var(--spacing-12);
    color: var(--color-mute);
    font-size: var(--text-sm);
  }
  .footer a { color: var(--color-ink); }
  .microcopy { font-size: var(--text-xs); margin-top: var(--spacing-2); }
</style>
