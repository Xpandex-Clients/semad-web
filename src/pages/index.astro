---
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Button from "@shared/ui/primitives/Button.astro";
import FaqAccordion from "@shared/ui/islands/FaqAccordion.tsx";
import JsonLd from "@shared/ui/seo/JsonLd.astro";
import {
  jsonLdGraph,
  medicalClinicSchema,
  websiteSchema,
  physicianRefSchema,
} from "@shared/seo/schemas";
import heroPortrait from "@assets/images/cemad-hero-portrait.png";
import mirrorImg from "@assets/images/cemad-mirror-reflection.png";
import method1 from "@assets/images/cemad-method-1.png";
import method2 from "@assets/images/cemad-method-2.png";
import method3 from "@assets/images/cemad-method-3.png";
import method4 from "@assets/images/cemad-method-4.png";
import faqImg from "@assets/images/cemad-faq-portrait.png";
import ctaBg from "@assets/images/cemad-cta-bg.png";

const homeGraph = jsonLdGraph(
  medicalClinicSchema(),
  websiteSchema(),
  physicianRefSchema(),
);

const methodPhases = [
  {
    n: 1,
    title: "Revelar",
    body:
      "Identificamos las causas profundas que impactan tu imagen: clínicas, emocionales y estructurales, para comprender tu punto de partida real.",
    img: method1,
  },
  {
    n: 2,
    title: "Restaurar",
    body:
      "Aplicamos tratamientos médicos de precisión que devuelven armonía y naturalidad, sin artificios ni estandarización.",
    img: method2,
  },
  {
    n: 3,
    title: "Reprogramar",
    body:
      "Establecemos protocolos estratégicos que previenen recaídas y te ayudan a mantener el control de tu proceso en el tiempo.",
    img: method3,
  },
  {
    n: 4,
    title: "Reintegrar",
    body:
      "Integramos los resultados en tu vida diaria, potenciando tu identidad y asegurando que tu imagen refleje quién eres en esencia.",
    img: method4,
  },
];

const homeFaqs = [
  {
    q: "¿En qué se diferencia CEMAD de otras clínicas estéticas?",
    a: "Restauramos tu identidad con rigor médico, no buscamos estandarizar. Cada plan parte del diagnóstico, no del catálogo.",
  },
  {
    q: "¿Qué es el Método Kintsugi?",
    a: "Un enfoque clínico inspirado en el arte japonés de restaurar con oro lo que se ha roto. Cuatro fases — Revelar, Restaurar, Reprogramar y Reintegrar — para devolver fuerza, naturalidad y autenticidad a tu imagen sin transformarla.",
  },
  {
    q: "¿Los resultados son naturales?",
    a: "Sí. La filosofía CEMAD prioriza preservar la identidad del paciente; trabajamos con diseño facial individualizado, no con protocolos estándar.",
  },
];

const services = [
  {
    title: "Medicina Estética",
    summary: "Tratamientos faciales y corporales mínimamente invasivos: armonización, rellenos, neuromoduladores, bioestimulación.",
    href: "/medicina-estetica",
  },
  {
    title: "Centro Capilar",
    summary: "Tricología, regeneración con PRP y cirugía de implante mediante micropunción FUE.",
    href: "/centro-capilar",
  },
  {
    title: "Medicina Integrativa",
    summary: "Diagnóstico hormonal y nutricional, sueroterapia IV y programas anti-aging que tratan la causa, no el síntoma.",
    href: "/medicina-integrativa",
  },
];
---

<Layout>
  <Fragment slot="head">
    <JsonLd data={homeGraph} />
  </Fragment>

  <main id="main">
    <!-- HERO full-bleed (Figma 160:576) ============================== -->
    <section class="relative isolate -mt-[var(--header-overlap,0)] overflow-hidden bg-[var(--color-paper)]">
      <div class="relative aspect-[16/9] sm:aspect-[3/2] lg:aspect-[16/9] xl:aspect-[2/1] w-full overflow-hidden">
        <Picture
          src={heroPortrait}
          alt="Retrato editorial CEMAD — mujer iluminada por un haz dorado"
          widths={[768, 1024, 1440, 1920]}
          sizes="100vw"
          formats={["avif", "webp"]}
          quality={84}
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 h-full w-full object-cover object-[center_30%]"
        />
      </div>
      <!-- Título overlay sobre fondo paper (debajo del image bleed) -->
      <div class="mx-auto max-w-[var(--container-wide)] px-[clamp(1rem,4vw,2rem)] pt-8 pb-2">
        <h1 class="font-[family-name:var(--font-display)] font-light leading-[0.95] text-[var(--color-ink)]">
          <span class="block text-[clamp(1.75rem,3.6vw,3rem)]">
            No transformamos tu imagen.
          </span>
          <em class="block not-italic italic text-[clamp(3.5rem,8.5vw,7.5rem)] font-normal mt-1 -indent-[0.1em]">
            <span class="inline-block w-[clamp(2rem,4vw,3rem)] h-[2px] bg-[var(--color-gold)] align-middle mr-3 mb-3"></span>La revelamos.
          </em>
        </h1>
      </div>
    </section>

    <!-- Hero copy block (Figma 02): 2-col split bajo el hero -->
    <Section tone="paper" spacing="default">
      <div class="grid lg:grid-cols-[0.85fr_1fr] gap-10 lg:gap-16 items-start">
        <p class="text-sm text-[var(--color-mute)] leading-relaxed max-w-[40ch]">
          <strong class="text-[var(--color-ink)] font-medium">Medicina de Precisión con Alma:</strong>
          recupera el control estratégico de tu imagen, con resultados
          naturales y un acompañamiento médico profundo.
        </p>
        <div>
          <p class="text-[var(--color-ink-soft)] leading-relaxed text-[1.0625rem] max-w-[52ch]">
            Convierte tu imagen en tu activo más estratégico. Con el Método
            Kintsugi, restauramos tu identidad con rigor médico, precisión
            estética y respeto absoluto a tu esencia.
          </p>
          <Button href="/contacto" variant="outline" size="md" class="mt-8 uppercase tracking-[0.18em] text-[11px]">
            Reserva tu Auditoría de Imagen →
          </Button>
        </div>
      </div>
    </Section>

    <!-- PILAR: Método Kintsugi narrativo ========================== -->
    <Section tone="paper" spacing="loose">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative aspect-[4/3] overflow-hidden rounded-[var(--radius-md)] shadow-[var(--shadow-card)] order-2 lg:order-1">
          <Picture
            src={mirrorImg}
            alt="Reflejo en espejo — proceso de revelación CEMAD"
            widths={[480, 768, 1024]}
            sizes="(min-width: 1024px) 600px, 92vw"
            formats={["avif", "webp"]}
            quality={80}
            class="absolute inset-0 h-full w-full object-cover"
          />
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="font-[family-name:var(--font-display)] font-light leading-[1.04] text-[clamp(3rem,6vw,5.5rem)]">
            <span class="block text-[var(--color-ink)]">Método</span>
            <span class="block text-[var(--color-gold)] italic font-normal">Kintsugi</span>
          </h2>
          <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
          <p class="mt-6 max-w-[56ch] text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
            Nos inspiramos en el arte japonés de restaurar con oro lo que ha
            sido dañado. Así es nuestro enfoque médico-estético: en cuatro
            fases — <strong class="text-[var(--color-ink)] font-medium">Revelar, Restaurar, Reprogramar y Reintegrar</strong> —
            construimos contigo un camino único que devuelve fuerza, naturalidad
            y autenticidad a tu imagen.
          </p>
          <Button href="/metodo-kintsugi" variant="ghost" size="md" class="mt-8 -ml-3">
            Descubre el Método completo →
          </Button>
        </div>
      </div>
    </Section>

    <!-- FRASE PILAR =============================================== -->
    <Section tone="paper-soft" spacing="default">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="font-[family-name:var(--font-display)] font-light italic text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.15] text-[var(--color-ink)]">
          El método que honra tu historia y revela tu esencia.
        </h2>
      </div>
    </Section>

    <!-- 4 FASES DEL MÉTODO ======================================== -->
    <Section tone="paper" spacing="loose">
      <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 list-none p-0 m-0">
        {methodPhases.map((p) => (
          <li>
            <div class="aspect-[3/4] overflow-hidden rounded-[var(--radius-sm)] mb-5">
              <Picture
                src={p.img}
                alt={`Fase ${p.n}: ${p.title}`}
                widths={[320, 480, 768]}
                sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 92vw"
                formats={["avif", "webp"]}
                quality={78}
                class="h-full w-full object-cover transition-transform duration-700 ease-[var(--ease-out)] hover:scale-[1.03]"
              />
            </div>
            <span class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-gold-dark)] font-semibold">
              Fase {p.n}
            </span>
            <h3 class="mt-2 font-[family-name:var(--font-display)] font-normal text-[clamp(1.5rem,2.5vw,2rem)] text-[var(--color-ink)] leading-tight">
              {p.title}
            </h3>
            <p class="mt-3 text-sm text-[var(--color-mute)] leading-relaxed">
              {p.body}
            </p>
          </li>
        ))}
      </ul>
    </Section>

    <!-- SERVICIOS PRINCIPALES ===================================== -->
    <Section tone="paper-soft" spacing="loose">
      <div class="mb-12 text-center">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-gold)] italic font-normal">
          Servicios principales
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)] mx-auto"></div>
      </div>
      <ul class="grid md:grid-cols-3 gap-6 list-none p-0">
        {services.map((s) => (
          <li>
            <a
              href={s.href}
              class="group block rounded-[var(--radius-sm)] bg-[var(--color-paper)] p-8 h-full transition-shadow duration-300 ease-[var(--ease-out)] hover:shadow-[var(--shadow-hover)] border border-[var(--color-paper-warm)]"
            >
              <h3 class="font-[family-name:var(--font-display)] text-[1.5rem] text-[var(--color-ink)] leading-tight transition-colors group-hover:text-[var(--color-gold-dark)]">
                {s.title}
              </h3>
              <p class="mt-3 text-sm text-[var(--color-mute)] leading-relaxed">
                {s.summary}
              </p>
              <span class="link-reveal mt-6 inline-block text-[11px] uppercase tracking-[0.18em] font-semibold text-[var(--color-ink)]">
                Saber más →
              </span>
            </a>
          </li>
        ))}
      </ul>
    </Section>

    <!-- TRUST: 120 pacientes + testimonio 5-star (Figma 09-10) ====== -->
    <Section tone="ink" spacing="loose" class="relative overflow-hidden">
      <div class="absolute inset-0 -z-0">
        <Picture
          src={faqImg}
          alt=""
          widths={[1024, 1440, 1920]}
          sizes="100vw"
          formats={["avif", "webp"]}
          quality={68}
          loading="lazy"
          class="h-full w-full object-cover opacity-30"
        />
        <div class="absolute inset-0 bg-[var(--color-ink)]/70"></div>
      </div>
      <div class="relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center text-[var(--color-paper)]">
        <div>
          <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] leading-[1.05]">
            <span class="block">Más de 120 pacientes</span>
            <em class="block not-italic italic text-[var(--color-gold)] font-normal">
              <span class="inline-block w-[clamp(2rem,4vw,3rem)] h-[2px] bg-[var(--color-gold)] align-middle mr-3 mb-2"></span>nos avalan
            </em>
          </h2>
          <ul class="mt-8 space-y-2 list-none p-0 text-sm text-[var(--color-paper)]/85">
            <li>+1.000 cirugías capilares</li>
            <li>+10 años de experiencia clínica</li>
            <li>6 másteres universitarios</li>
            <li>Reseñas con 5 estrellas en múltiples plataformas</li>
          </ul>
        </div>
        <figure class="bg-[var(--color-gold)]/95 text-[var(--color-ink)] p-8 lg:p-10 rounded-[var(--radius-sm)] shadow-[var(--shadow-card)]">
          <div aria-label="Valoración 5 estrellas" class="flex items-center gap-1 text-[var(--color-ink)]">
            {Array.from({ length: 5 }).map(() => (
              <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor" aria-hidden="true">
                <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.2 2.8 1-5.9L1.5 7.7l5.9-.9L10 1.5z" />
              </svg>
            ))}
          </div>
          <blockquote class="mt-4 font-[family-name:var(--font-display)] italic text-[1.0625rem] leading-relaxed">
            "No me borraron, me devolvieron. Hoy mi imagen refleja quién soy de verdad."
          </blockquote>
          <figcaption class="mt-4 text-xs uppercase tracking-[0.18em] text-[var(--color-ink-soft)] font-semibold">
            — Cliente CEMAD
          </figcaption>
        </figure>
      </div>
    </Section>

    <!-- POR QUÉ CEMAD: 4 bullets + retrato (Figma 11) ============== -->
    <Section tone="paper" spacing="loose">
      <div class="grid lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-16 items-center">
        <ul class="space-y-7 list-none p-0 max-w-[42ch]">
          <li class="flex gap-4">
            <span class="mt-2 size-2 rounded-full bg-[var(--color-gold)] shrink-0" aria-hidden="true"></span>
            <span class="text-[var(--color-ink)] font-[family-name:var(--font-display)] italic text-[1.0625rem] leading-snug">
              Transparencia en todo el proceso.
            </span>
          </li>
          <li class="flex gap-4">
            <span class="mt-2 size-2 rounded-full bg-[var(--color-gold)] shrink-0" aria-hidden="true"></span>
            <span class="text-[var(--color-ink)] font-[family-name:var(--font-display)] italic text-[1.0625rem] leading-snug">
              Diagnóstico profundo y personalizado.
            </span>
          </li>
          <li class="flex gap-4">
            <span class="mt-2 size-2 rounded-full bg-[var(--color-gold)] shrink-0" aria-hidden="true"></span>
            <span class="text-[var(--color-ink)] font-[family-name:var(--font-display)] italic text-[1.0625rem] leading-snug">
              Resultados naturales y armónicos.
            </span>
          </li>
          <li class="flex gap-4">
            <span class="mt-2 size-2 rounded-full bg-[var(--color-gold)] shrink-0" aria-hidden="true"></span>
            <span class="text-[var(--color-ink)] font-[family-name:var(--font-display)] italic text-[1.0625rem] leading-snug">
              Experiencia respaldada: más de 1.000 cirugías con éxito.
            </span>
          </li>
        </ul>
        <div class="aspect-[4/5] overflow-hidden rounded-[var(--radius-sm)] shadow-[var(--shadow-card)]">
          <Picture
            src={mirrorImg}
            alt="Retrato editorial CEMAD — confianza y diagnóstico"
            widths={[480, 768, 1024]}
            sizes="(min-width: 1024px) 540px, 92vw"
            formats={["avif", "webp"]}
            quality={80}
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </Section>

    <!-- FAQ =================================================== -->
    <Section tone="paper" spacing="loose">
      <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-20 items-start">
        <div class="aspect-[4/5] overflow-hidden rounded-[var(--radius-sm)] shadow-[var(--shadow-card)]">
          <Picture
            src={faqImg}
            alt="Tratamiento médico-estético en cabina CEMAD"
            widths={[480, 768, 1024]}
            sizes="(min-width: 1024px) 480px, 92vw"
            formats={["avif", "webp"]}
            quality={80}
            class="h-full w-full object-cover"
          />
        </div>
        <div>
          <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] leading-[1.05]">
            <span class="block text-[var(--color-ink)]">Preguntas</span>
            <span class="block text-[var(--color-gold)] italic">frecuentes</span>
          </h2>
          <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
          <div class="mt-8">
            <FaqAccordion client:visible items={homeFaqs} />
          </div>
        </div>
      </div>
    </Section>

    <!-- CTA CIERRE EDITORIAL (Figma 13) ======================== -->
    <Section tone="ink" spacing="loose" class="relative overflow-hidden">
      <div class="absolute inset-0 -z-0">
        <Picture
          src={ctaBg}
          alt=""
          widths={[1024, 1440, 1920]}
          sizes="100vw"
          formats={["avif", "webp"]}
          quality={70}
          loading="lazy"
          class="h-full w-full object-cover opacity-45"
        />
        <div class="absolute inset-0 bg-[var(--color-ink)]/50"></div>
      </div>
      <div class="relative z-10 text-center max-w-3xl mx-auto text-[var(--color-paper)]">
        <h2 class="font-[family-name:var(--font-display)] font-normal italic text-[clamp(2.25rem,4.5vw,3.5rem)] leading-[1.15]">
          Tu imagen merece respeto,<br />
          <span class="text-[var(--color-gold)]">precisión y estrategia</span>
        </h2>
        <div class="mt-10 flex gap-3 justify-center flex-wrap">
          <Button
            href="/contacto"
            variant="outline"
            size="lg"
            class="text-[var(--color-paper)] border-[var(--color-paper)]/70 hover:bg-white/10 hover:border-[var(--color-paper)] uppercase tracking-[0.18em] text-[11px]"
          >
            Reserva tu Auditoría de Imagen →
          </Button>
          <Button href="/musas-cemad" variant="outline" size="lg" class="text-[var(--color-paper)] border-[var(--color-paper)]/70 hover:bg-white/10 hover:border-[var(--color-paper)]">
            Ver Musas CEMAD
          </Button>
        </div>
      </div>
    </Section>
  </main>
</Layout>
