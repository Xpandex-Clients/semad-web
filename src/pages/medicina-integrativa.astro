---
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Button from "@shared/ui/primitives/Button.astro";
import PageHero from "@shared/ui/layout/PageHero.astro";
import heroImg from "@assets/images/page-integrativa-hero.png";
import diag1 from "@assets/images/integrativa-1.png";
import diag2 from "@assets/images/integrativa-2.png";
import diag3 from "@assets/images/integrativa-3.png";
import legadoImg from "@assets/images/integrativa-legado.png";

const triada = [
  {
    n: "01",
    title: "Oligoscan",
    sub: "Análisis de Minerales y Metales Pesados",
    body:
      "Medición no invasiva del nivel de minerales esenciales (zinc, magnesio, selenio) y detección de metales pesados tóxicos (mercurio, plomo, aluminio). Identifica déficits que impactan energía, piel, cabello y sistema inmune.",
    img: diag1,
  },
  {
    n: "02",
    title: "Biopsia Digital",
    sub: "Evaluación Celular Integral",
    body:
      "Análisis del estado de tus sistemas mediante tecnología no invasiva: sistema cardiovascular, función digestiva, estrés oxidativo celular, balance hormonal y calidad del sueño.",
    img: diag2,
  },
  {
    n: "03",
    title: "Analíticas Funcionales",
    sub: "Marcadores de Salud Profunda",
    body:
      "Perfil hormonal completo, marcadores de inflamación, niveles de vitaminas (D, B12, ácido fólico), función tiroidea avanzada y marcadores de salud metabólica.",
    img: diag3,
  },
];

const decadas = [
  {
    label: "La Década de la Excelencia",
    range: "40-50 años",
    filosofia:
      "Optimización de la salud en su mejor momento: previene el desgaste, mantiene el rendimiento físico y mental, sostiene la vitalidad.",
    planes: [
      { name: 'Plan "Esencia 40"', body: "Diagnóstico funcional anual, sueroterapia trimestral, equilibrio hormonal preventivo y protocolos nutricionales antiinflamatorios." },
      { name: 'Plan "Plenitud 40"', body: "Todo lo de Esencia + INDIBA® para regeneración celular + acompañamiento nutricional personalizado + medicina del rendimiento." },
      { name: 'Plan "Singular 40"', body: "Medicina personalizada con máximo acompañamiento: revisiones bimestrales, MTC, fitoterapia y planes terapéuticos a medida." },
    ],
  },
  {
    label: "La Década de la Maestría",
    range: "50-60 años",
    filosofia:
      "Transición consciente y vitalidad sostenida en una etapa de cambios fisiológicos importantes. Acompañamiento médico cercano.",
    planes: [
      { name: 'Plan "Esencia 50"', body: "Diagnóstico hormonal completo, gestión de transición menopáusica/andropausia, sueroterapia mensual y protocolos cardiovascular y óseo." },
      { name: 'Plan "Plenitud 50"', body: "Esencia 50 + tecnología INDIBA® + acompañamiento emocional + protocolos del sueño y cognitivos." },
      { name: 'Plan "Singular 50"', body: "Plan terapéutico dual (occidental + MTC), revisiones bimestrales y plan de longevidad integral." },
    ],
  },
  {
    label: "La Década de la Vitalidad",
    range: "60-70 años",
    filosofia:
      "Programa de estabilización metabólica y hormonal. Mantener autonomía, energía y claridad mental para una vida plena.",
    planes: [
      { name: 'Plan "Esencia 60"', body: "Diagnóstico funcional completo (Oligoscan + Biopsia Digital + analíticas), equilibrio hormonal, protocolos nutricionales antiinflamatorios, sueroterapia mensual y seguimiento trimestral." },
      { name: 'Plan "Plenitud 60"', body: "Esencia 60 + INDIBA® + Medicina Tradicional China + protocolos de movilidad articular." },
      { name: 'Plan "Singular 60"', body: "Medicina personalizada con máximo acompañamiento: revisiones bimestrales y plan terapéutico dual." },
    ],
  },
  {
    label: "La Década de la Sapiencia",
    range: "70-80 años",
    filosofia:
      "Preservación de autonomía, vitalidad cognitiva y bienestar profundo.",
    planes: [
      { name: 'Plan "Esencia 70"', body: "Programa de mantenimiento de funciones vitales. Diagnóstico funcional y ajuste de tratamientos, sueroterapia de mantenimiento, protocolos para salud cardiovascular y cognitiva, seguimiento trimestral." },
      { name: 'Plan "Plenitud 70"', body: "Programa de regeneración profunda con fusión de tecnologías. Esencia 70 + INDIBA® (radiofrecuencia para regeneración celular y reducción de dolor articular) + Medicina Tradicional China + protocolos de movilidad." },
      { name: 'Plan "Singular 70"', body: "Programa de medicina personalizada con máximo acompañamiento." },
    ],
  },
  {
    label: "La Década del Legado",
    range: "80+ años",
    filosofia:
      "Confort, dignidad y calidad de vida en la etapa más sabia.",
    planes: [
      { name: 'Plan "Esencia 80+"', body: "Programa de bienestar y manejo de molestias. Tratamientos para dolor articular y movilidad, sueroterapia de vitalidad, acompañamiento médico mensual." },
      { name: 'Plan "Plenitud 80+"', body: "Esencia 80+ + soporte cognitivo y emocional + tecnología INDIBA® adaptada + plan nutricional para conservar masa muscular." },
      { name: 'Plan "Singular 80+"', body: "Acompañamiento médico domiciliario opcional y plan integral diseñado contigo y tus cuidadores." },
    ],
  },
];

const programasMujer = [
  {
    title: "Programa Equilibrio Premenopáusico",
    range: "40-50 años",
    body: "Balance hormonal natural, manejo de síntomas premenopáusicos, preservación de densidad ósea y vitalidad.",
  },
  {
    title: "Programa Transición Menopáusica",
    range: "50-60 años",
    body: "Gestión de síntomas de menopausia (sofocos, insomnio, cambios de ánimo), terapia hormonal bioidéntica cuando corresponde, protección cardiovascular y ósea.",
  },
  {
    title: "Programa Plenitud Post-Menopáusica",
    range: "60+ años",
    body: "Mantenimiento de vitalidad, salud cognitiva, movilidad y bienestar emocional tras la menopausia.",
  },
];
---

<Layout
  title="Medicina Integrativa y Longevidad — CEMAD"
  description="Medicina Integrativa CEMAD: tríada diagnóstica (Oligoscan, Biopsia Digital, analíticas funcionales), sueroterapia y programa Legado y Plenitud para vivir con vitalidad en cada década."
>
  <main id="main">
    <PageHero
      image={heroImg}
      alt="Medicina integrativa CEMAD — composición editorial"
      focal="center 35%"
      eyebrow="Construye tu Mejor Versión,"
      title="a Cualquier"
      subtitle="Edad"
    />

    <!-- INTRO -->
    <Section tone="paper-soft" spacing="default" width="narrow">
      <div class="max-w-[68ch] mx-auto">
        <p class="text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
          En CEMAD comprendemos que la belleza externa es reflejo de la salud
          interna. No puedes tener piel radiante con déficits nutricionales. No
          puedes tener energía sostenida con hormonas desequilibradas. No
          puedes envejecer con vitalidad sin abordar las causas profundas del
          deterioro.
        </p>
        <p class="mt-6 text-[var(--color-mute)] leading-relaxed">
          Nuestra Medicina Integrativa fusiona dos mundos:
          <strong class="text-[var(--color-ink)] font-medium">diagnóstico occidental de precisión</strong>
          (analíticas funcionales avanzadas, tecnología Oligoscan y biopsia digital)
          y la <strong class="text-[var(--color-ink)] font-medium">sabiduría de la Medicina Tradicional China</strong>
          (equilibrio energético, acupuntura y fitoterapia).
        </p>
        <p class="mt-6 font-[family-name:var(--font-display)] italic text-[var(--color-ink)] text-xl leading-snug">
          El resultado es un enfoque único que restaura el equilibrio profundo
          de tu organismo para que vivas con vitalidad, claridad mental y
          bienestar sostenido en cada década de tu vida.
        </p>
      </div>
    </Section>

    <!-- TRÍADA DIAGNÓSTICA -->
    <Section tone="paper" spacing="loose">
      <div class="mb-12 max-w-3xl">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-ink)] leading-[1.05]">
          <span class="block">La Tríada Diagnóstica</span>
          <em class="block not-italic italic text-[var(--color-gold)]">CEMAD</em>
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
        <p class="mt-6 text-[var(--color-mute)] leading-relaxed">
          Antes de diseñar cualquier programa, realizamos una evaluación
          completa de tu estado de salud profundo mediante tecnologías de
          vanguardia.
        </p>
      </div>
      <ul class="grid md:grid-cols-3 gap-8 list-none p-0">
        {triada.map((t) => (
          <li>
            <div class="aspect-[4/5] overflow-hidden rounded-[var(--radius-sm)] mb-6">
              <Picture src={t.img} alt={t.title} widths={[320, 480]} sizes="(min-width: 768px) 33vw, 92vw" formats={["avif","webp"]} quality={80} class="h-full w-full object-cover" />
            </div>
            <span class="font-[family-name:var(--font-display)] italic text-[var(--color-gold)] text-2xl">
              {t.n}
            </span>
            <h3 class="mt-2 font-[family-name:var(--font-display)] text-[1.5rem] text-[var(--color-ink)] leading-tight">
              {t.title}
            </h3>
            <p class="mt-1 font-[family-name:var(--font-display)] italic text-[var(--color-gold-dark)] text-sm">
              {t.sub}
            </p>
            <p class="mt-4 text-sm text-[var(--color-mute)] leading-relaxed">{t.body}</p>
          </li>
        ))}
      </ul>
    </Section>

    <!-- PROGRAMA LEGADO Y PLENITUD: intro -->
    <Section tone="paper-soft" spacing="loose">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="aspect-[4/5] overflow-hidden rounded-[var(--radius-sm)]">
          <Picture src={legadoImg} alt="Programa Legado y Plenitud" widths={[480, 768, 1024]} sizes="(min-width: 1024px) 540px, 92vw" formats={["avif","webp"]} quality={80} class="h-full w-full object-cover" />
        </div>
        <div>
          <h2 class="font-[family-name:var(--font-display)] text-[clamp(2.25rem,4.5vw,3.25rem)] text-[var(--color-ink)] leading-[1.1]">
            Programa <em class="not-italic italic text-[var(--color-gold)]">Legado y Plenitud</em>
          </h2>
          <p class="mt-3 font-[family-name:var(--font-display)] italic text-[var(--color-gold)] text-lg">
            Longevidad por Etapa Vital
          </p>
          <p class="mt-6 text-[var(--color-mute)] leading-relaxed">
            El envejecimiento no es un declive inevitable. Es una etapa de
            transformación que puede vivirse con vitalidad, propósito y
            bienestar cuando abordas las causas profundas del deterioro.
          </p>
          <p class="mt-4 text-[var(--color-mute)] leading-relaxed">
            Nuestro Programa <em>Legado y Plenitud</em> está diseñado por
            décadas vitales, reconociendo que cada etapa tiene necesidades
            fisiológicas y emocionales únicas.
          </p>
        </div>
      </div>
    </Section>

    <!-- 5 DÉCADAS (Figma 06-09) ===================================== -->
    <Section tone="paper" spacing="loose">
      <div class="max-w-3xl mb-12">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] text-[var(--color-ink)] leading-[1.05]">
          <span class="block">Longevidad por etapa vital:</span>
          <em class="block not-italic italic text-[var(--color-gold)]">Vitalidad sostenida en cada década</em>
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
      </div>
      <ol class="space-y-16 list-none p-0 m-0">
        {decadas.map((d) => (
          <li class="border-t border-[var(--color-paper-warm)] pt-10">
            <div class="grid lg:grid-cols-[1fr_2fr] gap-10 lg:gap-16">
              <div>
                <p class="font-[family-name:var(--font-display)] italic text-[var(--color-gold)] text-lg">
                  {d.range}
                </p>
                <h3 class="mt-2 font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] text-[var(--color-ink)] leading-[1.1] font-normal">
                  {d.label}
                </h3>
                <p class="mt-5 text-xs uppercase tracking-[0.18em] text-[var(--color-gold-dark)] font-semibold">
                  Filosofía
                </p>
                <p class="mt-2 text-sm text-[var(--color-mute)] leading-relaxed">
                  {d.filosofia}
                </p>
              </div>
              <ul class="grid md:grid-cols-3 gap-4 list-none p-0">
                {d.planes.map((p) => (
                  <li class="bg-[var(--color-paper-soft)] p-5 rounded-[var(--radius-sm)] border border-[var(--color-paper-warm)]">
                    <p class="font-[family-name:var(--font-display)] italic text-[var(--color-ink)] text-base leading-tight">
                      {p.name}
                    </p>
                    <p class="mt-3 text-[13px] text-[var(--color-mute)] leading-relaxed">
                      {p.body}
                    </p>
                  </li>
                ))}
              </ul>
            </div>
          </li>
        ))}
      </ol>
    </Section>

    <!-- PROGRAMAS MUJER (Figma 09-10) ============================== -->
    <Section tone="paper-soft" spacing="loose">
      <div class="max-w-3xl mb-10">
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] text-[var(--color-ink)] leading-[1.05]">
          <span class="block">Salud hormonal femenina,</span>
          <em class="block not-italic italic text-[var(--color-gold)]">en cada etapa</em>
        </h2>
        <div class="mt-4 w-[100px] h-[2px] bg-[var(--color-gold)]"></div>
      </div>
      <ul class="grid md:grid-cols-3 gap-6 list-none p-0">
        {programasMujer.map((p) => (
          <li class="bg-[var(--color-paper)] p-7 rounded-[var(--radius-sm)] border border-[var(--color-paper-warm)] shadow-[var(--shadow-card)]">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-gold-dark)] text-sm">
              {p.range}
            </p>
            <h3 class="mt-2 font-[family-name:var(--font-display)] text-[1.25rem] text-[var(--color-ink)] leading-tight">
              {p.title}
            </h3>
            <p class="mt-4 text-sm text-[var(--color-mute)] leading-relaxed">
              {p.body}
            </p>
          </li>
        ))}
      </ul>
    </Section>

    <!-- CTA -->
    <Section tone="ink" spacing="loose">
      <div class="text-center max-w-2xl mx-auto text-[var(--color-paper)]">
        <img src="/brand/cemad-logo-white.png" alt="" aria-hidden="true" width="160" class="mx-auto mb-6 opacity-95" />
        <h2 class="font-[family-name:var(--font-display)] font-light text-[clamp(2.25rem,4.8vw,3.5rem)] leading-[1.1]">
          Empieza con tu
          <em class="block mt-2 not-italic italic text-[var(--color-gold)] font-normal">Tríada Diagnóstica</em>
        </h2>
        <p class="mt-6 text-[var(--color-paper)]/85">Mapa completo de tu salud interna en una sola sesión.</p>
        <div class="mt-10">
          <Button href="/contacto" variant="primary" size="lg">Reserva tu Auditoría de Imagen →</Button>
        </div>
      </div>
    </Section>
  </main>
</Layout>
