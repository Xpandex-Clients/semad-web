---
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Section from "@shared/ui/primitives/Section.astro";
import Button from "@shared/ui/primitives/Button.astro";
import PageHero from "@shared/ui/layout/PageHero.astro";
import musasHero from "@assets/images/page-musas-hero.png";
import valentinaImg from "@assets/images/musa-valentina.png";
import julianImg from "@assets/images/musa-julian.png";
import camilaImg from "@assets/images/musa-camila.png";
import andresImg from "@assets/images/musa-andres.png";
import luciaImg from "@assets/images/musa-lucia.png";

const musas = [
  {
    name: "Valentina",
    age: 42,
    quote:
      "Durante años escondí mi cabello detrás de pañuelos y moños apretados. La alopecia me quitó mucho más que volumen; me quitó la libertad de mirarme sin miedo. En CEMAD aprendí que no se trataba solo de recuperar folículos, sino de reconciliarme con mi reflejo. Hoy mi cabello vuelve a moverse con el viento… y con él, mi historia.",
    treatments:
      "Diagnóstico tricológico completo, bioestimulación capilar con plasma rico en plaquetas, mesoterapia regenerativa y trasplante capilar de precisión con enfoque restaurativo.",
    img: valentinaImg,
  },
  {
    name: "Julián",
    age: 36,
    quote:
      "Creí que perder el cabello era parte del destino. Pero un día entendí que no tenía que resignarme. Vine a CEMAD buscando una solución estética, y encontré un equipo que entendió la raíz emocional de lo que estaba viviendo. Hoy me veo al espejo y me reconozco de nuevo: seguro, natural, completo.",
    treatments:
      "Diagnóstico con tricoscopia avanzada, injerto capilar FUE de precisión, terapia regenerativa con factores de crecimiento, y mantenimiento con bioestimulación capilar personalizada.",
    img: julianImg,
  },
  {
    name: "Camila",
    age: 47,
    quote:
      "Siempre fui exigente conmigo misma. Cada línea en mi rostro era una batalla con el paso del tiempo… hasta que entendí que no debía borrarlas, sino suavizarlas con respeto. En CEMAD sentí que me devolvían armonía, no una nueva cara. Hoy mi rostro cuenta mi historia con más calma y coherencia.",
    treatments:
      "Armonización facial integral con ácido hialurónico, neuromoduladores estratégicos, estimulación de colágeno con biorevitalizantes, y protocolo Kintsugi de balance facial.",
    img: camilaImg,
  },
  {
    name: "Andrés",
    age: 55,
    quote:
      "Pensé que la vitalidad era cosa de juventud. Pero cuando empecé a sentir el cansancio y el estrés reflejados en mi piel y mi ánimo, entendí que podía elegir un camino diferente. En CEMAD aprendí a tratar mi cuerpo como un sistema completo. Hoy me siento más claro, más fuerte y más presente.",
    treatments:
      "Diagnóstico integrativo completo (Oligoscan + analíticas funcionales), sueroterapia personalizada, equilibrio hormonal y programa Legado y Plenitud.",
    img: andresImg,
  },
  {
    name: "Lucía",
    age: 38,
    quote:
      "Había perdido la energía sin saber por qué. Dormía bien, comía bien… pero algo en mí no brillaba. En CEMAD entendieron lo que ni yo sabía expresar: que el cansancio también tiene causas invisibles. Hoy mi piel tiene luz, mi cuerpo tiene ritmo y mi mente, calma. Recuperé mi energía… y mi poder.",
    treatments:
      "Evaluación funcional integral, programa de medicina integrativa con micronutrición y sueroterapia, acompañamiento dermoestético con bioestimulación.",
    img: luciaImg,
  },
];
---

<Layout
  title="Musas CEMAD — Historias de Restauración y Poder Personal"
  description="Pacientes reales que comparten su historia con CEMAD. Restauración, transformación y reencuentro con la propia identidad."
>
  <main id="main">
    <PageHero
      image={musasHero}
      alt="Musas CEMAD — composición editorial"
      focal="center 30%"
      eyebrow="Musas"
      title="CEMAD:"
      subtitle="Historias de Restauración y Poder Personal"
    />

    <!-- INTRO -->
    <Section tone="paper-soft" spacing="default" width="narrow">
      <div class="max-w-[68ch] mx-auto">
        <h2 class="font-[family-name:var(--font-display)] text-[var(--color-gold)] italic font-normal text-[clamp(2rem,4vw,3rem)]">
          Introducción
        </h2>
        <p class="mt-6 text-[var(--color-mute)] leading-relaxed text-[1.0625rem]">
          En CEMAD no mostramos <em>"antes y después"</em> como si fueran trofeos.
          Honramos el viaje emocional de cada paciente. Cada Musa CEMAD es una
          persona real que confió en nosotros para restaurar algo más profundo
          que su imagen: su relación consigo misma. Aquí compartimos sus
          historias —con su permiso y su voz— para que comprendas que no estás
          solo en tu proceso y que la transformación real es posible.
        </p>
      </div>
    </Section>

    <!-- MUSAS -->
    <Section tone="paper" spacing="loose">
      <ul class="space-y-28 list-none p-0 m-0 max-w-6xl mx-auto">
        {musas.map((m, i) => (
          <li class={`grid lg:grid-cols-[0.95fr_1.05fr] gap-12 lg:gap-16 items-start ${i % 2 === 1 ? "lg:[&>*:first-child]:order-2" : ""}`}>
            <div class="relative">
              <span class="absolute -top-5 -left-3 lg:-left-6 z-10 font-[family-name:var(--font-display)] italic text-[clamp(4rem,8vw,7rem)] leading-none text-[var(--color-gold)]/95 select-none">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="aspect-[3/4] overflow-hidden rounded-none shadow-[var(--shadow-card)] bg-[var(--color-paper-soft)]">
                {m.img ? (
                  <Picture
                    src={m.img}
                    alt={`Retrato de ${m.name}, paciente CEMAD`}
                    widths={[400, 600, 800]}
                    sizes="(min-width: 1024px) 480px, 92vw"
                    formats={["avif", "webp"]}
                    quality={80}
                    loading="eager"
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <div class="h-full w-full flex items-center justify-center text-[var(--color-mute)] text-sm font-[family-name:var(--font-script)] italic">
                    Retrato pendiente
                  </div>
                )}
              </div>
            </div>
            <div class="lg:pt-8">
              <p class="text-[0.7rem] tracking-[0.22em] uppercase text-[var(--color-gold-dark)] font-medium">
                Musa CEMAD · {String(i + 1).padStart(2, "0")}
              </p>
              <h3 class="mt-3 font-[family-name:var(--font-display)] text-[clamp(2.25rem,4.5vw,3.25rem)] text-[var(--color-ink)] leading-[1.05] font-normal">
                {m.name},
                <span class="block text-[var(--color-gold)] italic">{m.age} años</span>
              </h3>
              <div class="mt-6 relative pl-6 border-l-2 border-[var(--color-gold)]">
                <span aria-hidden="true" class="absolute -top-2 -left-1 font-[family-name:var(--font-display)] italic text-[2.5rem] leading-none text-[var(--color-gold)]/80">
                  &ldquo;
                </span>
                <blockquote class="text-[var(--color-ink-soft)] leading-relaxed italic text-[1.0625rem]">
                  {m.quote}
                </blockquote>
              </div>
              <div class="mt-8 p-7 lg:p-8 bg-[var(--color-cream)]/40 border-l-4 border-[var(--color-gold)]">
                <p class="text-[0.7rem] tracking-[0.18em] uppercase text-[var(--color-gold-dark)] font-medium">
                  Tratamientos realizados
                </p>
                <p class="mt-3 text-[0.95rem] text-[var(--color-mute)] leading-relaxed">
                  {m.treatments}
                </p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </Section>

    <!-- CTA FOOTER -->
    <Section tone="ink" spacing="loose">
      <div class="text-center max-w-2xl mx-auto text-[var(--color-paper)]">
        <img src="/brand/cemad-logo-white.png" alt="" aria-hidden="true" width="160" class="mx-auto mb-6 opacity-95" />
        <h2 class="font-[family-name:var(--font-display)] font-light text-[clamp(2.25rem,4.8vw,3.5rem)] leading-[1.1]">
          ¿Lista para Convertirte en la
          <em class="block mt-2 not-italic italic text-[var(--color-gold)] font-normal">Próxima Musa CEMAD?</em>
        </h2>
        <p class="mt-6 text-[var(--color-paper)]/85">
          Cada Musa empieza con una conversación. Reserva la tuya.
        </p>
        <div class="mt-10">
          <Button href="/contacto" variant="primary" size="lg">
            Reserva tu Auditoría de Imagen →
          </Button>
        </div>
      </div>
    </Section>
  </main>
</Layout>
