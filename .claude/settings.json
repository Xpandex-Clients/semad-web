{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run *)",
      "Bash(npm exec *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b *)",
      "Bash(git checkout work/*)",
      "Bash(git checkout staging)",
      "Bash(git push origin work/*)",
      "Bash(git push origin staging)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(mkdir -p *)",
      "Bash(astro *)",
      "Bash(tsc *)",
      "Bash(biome *)",
      "Bash(playwright *)",
      "Bash(vitest *)",
      "Bash(lhci *)",
      "Bash(curl -sS http://localhost:*)",
      "Bash(curl -sI http://localhost:*)",
      "Read(**)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push --no-verify *)",
      "Bash(git commit --no-verify *)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME*)",
      "Edit(.env)",
      "Edit(.env.production)",
      "Edit(.env.local)",
      "Write(.env)",
      "Write(.env.production)",
      "Write(.env.local)",
      "Edit(client-input/**)",
      "Write(client-input/briefing-original.txt)",
      "Write(client-input/briefing-original/**)",
      "Write(client-input/assets/brand/CEMAD-manual-identidad.pdf)"
    ]
  },
  "env": {
    "ASTRO_TELEMETRY_DISABLED": "1"
  }
}
